---
import BaseLayout from '../layouts/BaseLayout.astro';
import { t } from '../i18n/utils';
import { routeMap } from '../i18n/routes';
import { pexelsMadeiraImages } from '../lib/pexelsImages';

const routes = routeMap.en;
---

<BaseLayout title="Page Not Found" description="" lang="en" noindex={true}>
  <div class="relative overflow-hidden">
    <section class="relative isolate overflow-hidden px-4 py-20 sm:px-6 lg:px-8 lg:py-28">
      <img
        src={pexelsMadeiraImages.machicoFireFestival.src}
        alt={pexelsMadeiraImages.machicoFireFestival.alt}
        class="absolute inset-0 -z-20 h-full w-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 -z-10 bg-[linear-gradient(112deg,rgba(8,21,30,0.8)_0%,rgba(8,21,30,0.62)_48%,rgba(8,21,30,0.78)_100%)]"></div>

      <div class="mx-auto max-w-3xl text-center text-white">
        <p class="eyebrow !border-white/30 !bg-white/10 !text-white/84">404</p>
        <h1 class="mt-5 text-balance text-5xl leading-[1.05] text-white sm:text-6xl lg:text-7xl">
          {t('en', 'notFound.title')}
        </h1>
        <p class="mx-auto mt-4 max-w-2xl text-base leading-relaxed text-white/82 sm:text-lg">
          {t('en', 'notFound.description')}
        </p>

        <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
          <a
            href={routes.home}
            class="inline-flex items-center justify-center rounded-full bg-white px-8 py-3 text-sm font-semibold uppercase tracking-[0.06em] text-charcoal transition-colors hover:bg-golden-sand"
          >
            {t('en', 'notFound.cta')}
          </a>
          <a
            href={routes.services}
            class="inline-flex items-center justify-center rounded-full border border-white/35 bg-white/8 px-8 py-3 text-sm font-semibold uppercase tracking-[0.06em] text-white backdrop-blur transition-colors hover:bg-white/20"
          >
            Explore Services
          </a>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
