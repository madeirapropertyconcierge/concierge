---
import BlogPostContent from '../../../components/pages/BlogPostContent.astro';
import { getLocalizedBlogPostBySlug } from '../../../lib/blogData';
const lang = 'en';
const slug = Astro.params.slug ?? '';
const post = slug ? await getLocalizedBlogPostBySlug(slug, lang) : null;

if (!post) {
  return Astro.redirect('/en/blog');
}
---

<BlogPostContent lang={lang} {...post} />
