---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Admin Image Library"
  description="Internal image library management page"
  lang="en"
  noindex={true}
>
  <section class="mx-auto max-w-3xl px-4 py-24 sm:px-6 lg:px-8">
    <div class="rounded-3xl border border-charcoal/15 bg-white/85 p-8 shadow-lg backdrop-blur">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-ocean-blue">Internal</p>
      <h1 class="mt-2 font-serif text-4xl text-charcoal">Image Library Workspace</h1>
      <p class="mt-4 text-base leading-relaxed text-charcoal/80">
        This page is intentionally not linked in navigation. Log in as admin, then use the CMS banner to manage the
        image library and apply images to content.
      </p>
      <button
        type="button"
        class="mt-6 inline-flex items-center justify-center rounded-full bg-charcoal px-5 py-2.5 text-xs font-semibold uppercase tracking-[0.08em] text-white transition-all duration-300 hover:-translate-y-0.5 hover:bg-ocean-blue"
        data-cms-open-login
      >
        Open Admin Login
      </button>
    </div>
  </section>
</BaseLayout>
