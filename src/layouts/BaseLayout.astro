---
import '../styles/global.css';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';
import VercelAnalytics from '../components/VercelAnalytics.astro';
import AdminShell from '../components/cms/AdminShell.astro';
import { SITE } from '../lib/constants';
import { t } from '../i18n/utils';
import type { Locale } from '../i18n/utils';
import { getAlternateRoute, routeMap } from '../i18n/routes';
import { getPageIdFromPath } from '../cms/page-id';
import { loadPageDocument } from '../cms/content-loader';

interface Props {
  title?: string;
  description?: string;
  lang?: Locale;
  ogImage?: string;
  twitterImage?: string;
  ogType?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  canonicalUrl?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title = SITE.name,
  description = '',
  lang = 'en',
  ogImage = '/images/madeira/funchal-bay.jpg',
  twitterImage = ogImage,
  ogType = 'website',
  publishedTime,
  modifiedTime,
  canonicalUrl,
  noindex = false,
  jsonLd,
} = Astro.props;

const normalizedTitle = title.trim();
const alternateLocale = lang === 'en' ? 'pt' : 'en';
const currentPath = Astro.url.pathname;
const enPath = lang === 'en' ? currentPath : getAlternateRoute(currentPath, 'en');
const ptPath = lang === 'pt' ? currentPath : getAlternateRoute(currentPath, 'pt');
const pageId = getPageIdFromPath(currentPath);
const cmsPage = await loadPageDocument(pageId);
const cmsSeo = cmsPage.seo[lang];

const effectiveBaseTitle = cmsSeo.title.trim() || normalizedTitle;
const pageTitle =
  effectiveBaseTitle === SITE.name || effectiveBaseTitle.includes(SITE.name)
    ? effectiveBaseTitle
    : `${effectiveBaseTitle} | ${SITE.name}`;
const effectiveDescription = cmsSeo.description.trim() || description;
const effectiveCanonical = cmsSeo.canonical.trim() || canonicalUrl || `${SITE.url}${Astro.url.pathname}`;
const resolvedCanonicalUrl = effectiveCanonical.startsWith('http')
  ? effectiveCanonical
  : `${SITE.url}${effectiveCanonical.startsWith('/') ? effectiveCanonical : `/${effectiveCanonical}`}`;
const ogSourceImage = cmsSeo.ogImage.trim() || ogImage;

function resolveMetadataOrigin(): string {
  const forwardedHost = Astro.request.headers.get('x-forwarded-host')?.trim();
  const forwardedProto = Astro.request.headers.get('x-forwarded-proto')?.trim() || 'https';
  if (forwardedHost && !forwardedHost.includes('localhost') && !forwardedHost.startsWith('127.0.0.1')) {
    return `${forwardedProto}://${forwardedHost}`;
  }

  const host = Astro.request.headers.get('host')?.trim();
  if (host && !host.includes('localhost') && !host.startsWith('127.0.0.1')) {
    return `${forwardedProto}://${host}`;
  }

  return SITE.url;
}

const metadataOrigin = resolveMetadataOrigin();

function resolveImageUrl(path: string): string {
  if (path.startsWith('http')) {
    return path;
  }

  const normalizedPath = path.startsWith('/') ? path : `/${path}`;
  return `${metadataOrigin}${normalizedPath}`;
}

const resolvedOgImage = resolveImageUrl(ogSourceImage);
const resolvedTwitterImage = resolveImageUrl(cmsSeo.ogImage.trim() || twitterImage);
const effectiveOgTitle = cmsSeo.ogTitle.trim() || pageTitle;
const effectiveOgDescription = cmsSeo.ogDescription.trim() || effectiveDescription;
const isBlogPage = currentPath.includes('/blog');

const globalJsonLd: Array<Record<string, unknown>> = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.url,
    email: SITE.email,
    telephone: SITE.phone,
    sameAs: [SITE.social.instagram, SITE.social.facebook, SITE.social.linkedin],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: SITE.name,
    url: SITE.url,
    inLanguage: ['en-US', 'pt-PT'],
  },
];

const pageJsonLd = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
const combinedJsonLd = [...globalJsonLd, ...pageJsonLd];
---

<!DOCTYPE html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{pageTitle}</title>
    <meta name="description" content={effectiveDescription} />
    <meta name="author" content={SITE.name} />
    <meta name="theme-color" content="#10202b" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {!noindex && <meta name="robots" content="index, follow, max-image-preview:large" />}
    <link rel="canonical" href={resolvedCanonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={effectiveOgTitle} />
    <meta property="og:description" content={effectiveOgDescription} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:url" content={resolvedCanonicalUrl} />
    <meta property="og:locale" content={lang === 'pt' ? 'pt_PT' : 'en_US'} />
    <meta property="og:locale:alternate" content={alternateLocale === 'pt' ? 'pt_PT' : 'en_US'} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={effectiveOgTitle} />
    <meta name="twitter:description" content={effectiveOgDescription} />
    <meta name="twitter:image" content={resolvedTwitterImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- hreflang -->
    <link rel="alternate" hreflang="en" href={`${SITE.url}${enPath}`} />
    <link rel="alternate" hreflang="pt" href={`${SITE.url}${ptPath}`} />
    <link rel="alternate" hreflang="x-default" href={`${SITE.url}${enPath}`} />

    {combinedJsonLd.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body class="min-h-screen flex flex-col bg-cream text-charcoal antialiased">
    <AdminShell pageId={pageId} locale={lang} isBlogPage={isBlogPage} />
    <Header lang={lang} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer lang={lang} />
    <VercelAnalytics />
    <CookieConsent
      lang={lang}
      labels={{
        message: t(lang, 'cookies.message'),
        accept: t(lang, 'cookies.accept'),
        decline: t(lang, 'cookies.decline'),
        learnMore: t(lang, 'cookies.learnMore'),
      }}
      privacyUrl={routeMap[lang].privacy}
    />
  </body>
</html>
