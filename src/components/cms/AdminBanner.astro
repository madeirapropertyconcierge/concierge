<div id="cms-admin-banner" class="cms-hidden cms-fixed cms-top-0 cms-left-0 cms-right-0 cms-z-top" data-admin-allow>
  <div class="cms-banner" data-admin-allow>
    <div class="cms-banner-top" data-admin-allow>
      <div class="cms-row cms-wrap cms-gap-2" data-admin-allow>
        <strong class="cms-admin-label" data-admin-allow>Admin</strong>
        <span id="cms-mode-label" class="cms-pill" data-admin-allow>View</span>
        <span id="cms-dirty-indicator" class="cms-pill cms-pill-neutral" data-admin-allow>Up to date</span>
        <span id="cms-fallback-warning" class="cms-pill cms-pill-warning cms-hidden" data-admin-allow>PT fallback active</span>
      </div>
      <p id="cms-status" class="cms-subtitle" data-admin-allow>Public view</p>
    </div>

    <div class="cms-actions" data-admin-allow>
      <button id="cms-toggle-mode" class="cms-btn cms-btn-primary" data-admin-allow>Edit content</button>
      <button id="cms-discard-changes" class="cms-btn cms-btn-muted" data-admin-allow>Discard changes</button>
      <button id="cms-edit-seo" class="cms-btn cms-btn-muted" data-admin-allow>SEO</button>
      <button id="cms-open-image-editor" class="cms-btn cms-btn-muted" data-admin-allow>Image details</button>
      <button id="cms-open-image-library" class="cms-btn cms-btn-muted" data-admin-allow>Image library</button>
      <button id="cms-open-blog-manager" class="cms-btn cms-btn-muted" data-admin-allow>Blog manager</button>
      <button id="cms-publish" class="cms-btn cms-btn-success" data-admin-allow>Publish</button>
      <button id="cms-logout" class="cms-btn cms-btn-muted" data-admin-allow>Logout</button>
    </div>
  </div>
</div>
