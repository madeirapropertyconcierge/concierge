---
import type { HTMLAttributes } from 'astro/types';
import { renderInlineMarkdown } from '../../cms/markdown';

interface Props extends HTMLAttributes<'a'> {
  id: string;
  selector: string;
  href: string;
  label: string;
}

const { id, selector, href, label, ...rest } = Astro.props;
---

<a
  href={href}
  {...rest}
  data-cms-field="link"
  data-cms-id={id}
  data-cms-selector={selector}
  data-cms-link-managed
  set:html={renderInlineMarkdown(label)}
/>
