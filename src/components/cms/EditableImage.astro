---
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'img'> {
  id: string;
  selector: string;
  src: string;
  alt: string;
}

const { id, selector, src, alt, ...rest } = Astro.props;
---

<img
  src={src}
  alt={alt}
  {...rest}
  data-cms-field="image"
  data-cms-id={id}
  data-cms-selector={selector}
/>
