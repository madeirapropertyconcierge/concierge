---
import { renderBlockMarkdown, renderInlineMarkdown } from '../../cms/markdown';

interface Props {
  id: string;
  selector: string;
  kind: 'inline' | 'block';
  value: string;
  as?: string;
  class?: string;
}

const { id, selector, kind, value, as = 'span', class: className, ...rest } = Astro.props;
const Tag = as as keyof HTMLElementTagNameMap;
const html = kind === 'block' ? renderBlockMarkdown(value) : renderInlineMarkdown(value);
---

<Tag
  {...rest}
  class={className}
  data-cms-field="text"
  data-cms-id={id}
  data-cms-selector={selector}
  data-cms-kind={kind}
  set:html={html}
/>
