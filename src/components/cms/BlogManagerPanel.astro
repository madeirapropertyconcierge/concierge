<div id="cms-blog-manager" class="cms-hidden cms-panel cms-panel-xl" data-admin-allow>
  <header class="cms-row cms-space-between" data-admin-allow>
    <h3 class="cms-title">Blog Manager</h3>
    <button id="cms-blog-manager-close" class="cms-btn cms-btn-muted" type="button" data-admin-allow>Close</button>
  </header>

  <div class="cms-row cms-wrap" data-admin-allow>
    <select id="cms-blog-select" data-admin-allow></select>
    <button id="cms-blog-new" class="cms-btn cms-btn-primary" type="button" data-admin-allow>New post</button>
    <button id="cms-blog-duplicate" class="cms-btn cms-btn-muted" type="button" data-admin-allow>Duplicate</button>
    <button id="cms-blog-delete" class="cms-btn cms-btn-danger" type="button" data-admin-allow>Delete</button>
  </div>

  <form id="cms-blog-form" class="cms-form" data-admin-allow>
    <section class="cms-section-card" data-admin-allow>
      <h4 class="cms-title-small" data-admin-allow>Post Setup</h4>
      <div class="cms-grid-2" data-admin-allow>
        <label class="cms-field" data-admin-allow>
          <span data-admin-allow>Slug</span>
          <input name="slug" required data-admin-allow />
        </label>
        <label class="cms-field" data-admin-allow>
          <span data-admin-allow>Status</span>
          <select name="status" data-admin-allow>
            <option value="draft">draft</option>
            <option value="published">published</option>
          </select>
        </label>
      </div>

      <div class="cms-grid-3" data-admin-allow>
        <label class="cms-field" data-admin-allow>
          <span data-admin-allow>Published at</span>
          <input name="publishedAt" placeholder="YYYY-MM-DD" data-admin-allow />
        </label>
        <label class="cms-field" data-admin-allow>
          <span data-admin-allow>Reading minutes</span>
          <input name="readingMinutes" type="number" min="1" step="1" data-admin-allow />
        </label>
        <label class="cms-field" data-admin-allow>
          <span data-admin-allow>Tags</span>
          <input name="tags" placeholder="tag1,tag2" data-admin-allow />
        </label>
      </div>

      <div class="cms-grid-2" data-admin-allow>
        <label class="cms-field" data-admin-allow>
          <span data-admin-allow>Cover image URL</span>
          <input name="coverImage" data-admin-allow />
        </label>
        <label class="cms-field" data-admin-allow>
          <span data-admin-allow>Cover alt (EN)</span>
          <input name="coverAltEn" data-admin-allow />
        </label>
      </div>

      <label class="cms-field" data-admin-allow>
        <span data-admin-allow>Cover alt (PT)</span>
        <input name="coverAltPt" data-admin-allow />
      </label>
    </section>

    <div class="cms-locale-grid" data-admin-allow>
      <section class="cms-section-card" data-admin-allow>
        <h4 class="cms-title-small" data-admin-allow>English Content</h4>
        <label class="cms-field" data-admin-allow>
          <span data-admin-allow>Title</span>
          <input name="titleEn" data-admin-allow />
        </label>
        <label class="cms-field" data-admin-allow>
          <span data-admin-allow>Excerpt</span>
          <textarea name="excerptEn" rows="2" data-admin-allow></textarea>
        </label>
        <label class="cms-field" data-admin-allow>
          <span data-admin-allow>Body (markdown)</span>
          <textarea name="bodyEn" rows="10" data-admin-allow></textarea>
        </label>
      </section>

      <section class="cms-section-card" data-admin-allow>
        <h4 class="cms-title-small" data-admin-allow>Portuguese Content</h4>
        <label class="cms-field" data-admin-allow>
          <span data-admin-allow>Title</span>
          <input name="titlePt" data-admin-allow />
        </label>
        <label class="cms-field" data-admin-allow>
          <span data-admin-allow>Excerpt</span>
          <textarea name="excerptPt" rows="2" data-admin-allow></textarea>
        </label>
        <label class="cms-field" data-admin-allow>
          <span data-admin-allow>Body (markdown)</span>
          <textarea name="bodyPt" rows="10" data-admin-allow></textarea>
        </label>
      </section>
    </div>

    <div class="cms-locale-grid" data-admin-allow>
      <section class="cms-section-card" data-admin-allow>
        <h4 class="cms-title-small" data-admin-allow>English SEO</h4>
        <label class="cms-field" data-admin-allow>
          <span data-admin-allow>SEO title</span>
          <input name="seoTitleEn" data-admin-allow />
        </label>
        <label class="cms-field" data-admin-allow>
          <span data-admin-allow>SEO description</span>
          <textarea name="seoDescEn" rows="2" data-admin-allow></textarea>
        </label>
        <label class="cms-field" data-admin-allow>
          <span data-admin-allow>OG title</span>
          <input name="ogTitleEn" data-admin-allow />
        </label>
        <label class="cms-field" data-admin-allow>
          <span data-admin-allow>OG description</span>
          <textarea name="ogDescEn" rows="2" data-admin-allow></textarea>
        </label>
        <label class="cms-field" data-admin-allow>
          <span data-admin-allow>OG image URL</span>
          <input name="ogImageEn" data-admin-allow />
        </label>
        <label class="cms-field" data-admin-allow>
          <span data-admin-allow>Canonical URL</span>
          <input name="canonicalEn" data-admin-allow />
        </label>
      </section>

      <section class="cms-section-card" data-admin-allow>
        <h4 class="cms-title-small" data-admin-allow>Portuguese SEO</h4>
        <label class="cms-field" data-admin-allow>
          <span data-admin-allow>SEO title</span>
          <input name="seoTitlePt" data-admin-allow />
        </label>
        <label class="cms-field" data-admin-allow>
          <span data-admin-allow>SEO description</span>
          <textarea name="seoDescPt" rows="2" data-admin-allow></textarea>
        </label>
        <label class="cms-field" data-admin-allow>
          <span data-admin-allow>OG title</span>
          <input name="ogTitlePt" data-admin-allow />
        </label>
        <label class="cms-field" data-admin-allow>
          <span data-admin-allow>OG description</span>
          <textarea name="ogDescPt" rows="2" data-admin-allow></textarea>
        </label>
        <label class="cms-field" data-admin-allow>
          <span data-admin-allow>OG image URL</span>
          <input name="ogImagePt" data-admin-allow />
        </label>
        <label class="cms-field" data-admin-allow>
          <span data-admin-allow>Canonical URL</span>
          <input name="canonicalPt" data-admin-allow />
        </label>
      </section>
    </div>

    <button type="submit" class="cms-btn cms-btn-success" data-admin-allow>Apply post changes</button>
  </form>
</div>
