---
import SharedPackageText from '../cms/SharedPackageText.astro';
import type { ServicePackage } from '../../lib/pageContent/packages';

interface Props {
  tier: ServicePackage;
  index: number;
  customQuoteLabel: string;
  primaryCtaLabel: string;
  projectCtaLabel: string;
  contactHref: string;
  includesLabel: string;
  idealForLabel: string;
}

const {
  tier,
  index,
  customQuoteLabel,
  primaryCtaLabel,
  projectCtaLabel,
  contactHref,
  includesLabel,
  idealForLabel,
} = Astro.props;
---

<article
  class:list={[
    'pricing-card premium-panel reveal flex h-full flex-col p-6 sm:p-7',
    index > 0 ? 'reveal-delay-1' : '',
  ]}
>
  <header class="min-h-[10.75rem]">
    <SharedPackageText
      packageKey={tier.key}
      field="tierLabel"
      value={tier.tierLabel}
      kind="inline"
      as="p"
      class="text-[0.7rem] font-semibold uppercase tracking-[0.16em] text-ocean-blue/85"
    />
    <SharedPackageText
      packageKey={tier.key}
      field="title"
      value={tier.title}
      kind="inline"
      as="h2"
      class="mt-2 text-3xl text-charcoal"
    />
    <SharedPackageText
      packageKey={tier.key}
      field="audience"
      value={tier.audience}
      kind="block"
      as="p"
      class="mt-2 text-sm leading-relaxed text-charcoal/66"
    />
  </header>

  <div
    class:list={[
      'mt-3 flex items-start',
      tier.price || tier.showQuoteLabel !== false ? 'min-h-[5.8rem]' : 'min-h-0',
    ]}
  >
    {tier.price ? (
      <div class="flex flex-col gap-1">
        <SharedPackageText
          packageKey={tier.key}
          field="priceHeadline"
          value={tier.price.headline}
          kind="inline"
          as="p"
          class="text-3xl leading-tight text-charcoal sm:text-4xl"
        />
        {tier.price.detail && (
          <SharedPackageText
            packageKey={tier.key}
            field="priceDetail"
            value={tier.price.detail}
            kind="block"
            as="p"
            class="max-w-[17rem] text-sm leading-relaxed text-charcoal/64"
          />
        )}
      </div>
    ) : (
      <div class="flex flex-col gap-1">
        {tier.showQuoteLabel !== false && (
          <p class="pricing-quote text-3xl text-charcoal">{customQuoteLabel}</p>
        )}
        <p
          aria-hidden="true"
          class:list={[
            'text-sm font-medium uppercase tracking-[0.06em]',
            tier.showQuoteLabel !== false ? 'invisible' : 'hidden',
          ]}
        >
          &nbsp;
        </p>
      </div>
    )}
  </div>

  <div
    class:list={[
      'flex flex-1 flex-col',
      tier.price || tier.showQuoteLabel !== false ? 'mt-6' : 'mt-2',
    ]}
  >
    <p class="text-[0.7rem] font-semibold uppercase tracking-[0.16em] text-ocean-blue/85">{includesLabel}</p>
    <ul class="mt-3 grid gap-3 text-sm text-charcoal/72">
      {tier.features.map((feature, featureIndex) => (
        <li class="flex items-start gap-2.5">
          <span class="mt-2 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-ocean-blue"></span>
          <SharedPackageText
            packageKey={tier.key}
            field="feature"
            index={featureIndex}
            value={feature}
            kind="block"
            as="span"
          />
        </li>
      ))}
    </ul>

    {tier.idealFor && (
      <div class="mt-6 border-t border-charcoal/10 pt-5">
        <p class="text-[0.7rem] font-semibold uppercase tracking-[0.16em] text-ocean-blue/85">{idealForLabel}</p>
        <SharedPackageText
          packageKey={tier.key}
          field="idealFor"
          value={tier.idealFor}
          kind="block"
          as="p"
          class="mt-2 text-sm leading-relaxed text-charcoal/72"
        />
      </div>
    )}
  </div>

  <a
    href={contactHref}
    class="mt-8 inline-flex w-full items-center justify-center rounded-full bg-charcoal px-6 py-3 text-xs font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-ocean-blue"
  >
    {tier.price ? primaryCtaLabel : projectCtaLabel}
  </a>
</article>
