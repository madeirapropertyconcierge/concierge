---
import EditableLink from '../cms/EditableLink.astro';
import EditableText from '../cms/EditableText.astro';
import SharedPackageText from '../cms/SharedPackageText.astro';
import type { CmsPageLinkValue, CmsPageTextValue } from '../../lib/pageContent/cmsPageText';
import type { ServicePackage } from '../../lib/pageContent/packages';

interface Props {
  tier: ServicePackage;
  index: number;
  customQuoteLabel: CmsPageTextValue;
  primaryCta: CmsPageLinkValue;
  projectCta: CmsPageLinkValue;
  includesLabel: CmsPageTextValue;
  idealForLabel: CmsPageTextValue;
}

const {
  tier,
  index,
  customQuoteLabel,
  primaryCta,
  projectCta,
  includesLabel,
  idealForLabel,
} = Astro.props;

const cta = tier.price ? primaryCta : projectCta;
---

<article
  class:list={[
    'pricing-card premium-panel reveal grid p-6 sm:p-7',
    index > 0 ? 'reveal-delay-1' : '',
  ]}
>
  <header>
    <SharedPackageText
      packageKey={tier.key}
      field="tierLabel"
      value={tier.tierLabel}
      kind="inline"
      as="p"
      class="text-[0.7rem] font-semibold uppercase tracking-[0.16em] text-ocean-blue/85"
    />
    <SharedPackageText
      packageKey={tier.key}
      field="title"
      value={tier.title}
      kind="inline"
      as="h2"
      class="mt-2 text-3xl text-charcoal"
    />
    <SharedPackageText
      packageKey={tier.key}
      field="audience"
      value={tier.audience}
      kind="inline"
      as="p"
      class="mt-2 text-sm leading-relaxed text-charcoal/66"
    />
  </header>

  <div class="flex items-start">
    {tier.price ? (
      <div class="flex flex-col gap-1">
        <SharedPackageText
          packageKey={tier.key}
          field="priceHeadline"
          value={tier.price.headline}
          kind="inline"
          as="p"
          class="text-3xl leading-tight text-charcoal sm:text-4xl"
        />
        {tier.price.detail && (
          <SharedPackageText
            packageKey={tier.key}
            field="priceDetail"
            value={tier.price.detail}
            kind="inline"
            as="p"
            class="max-w-[17rem] text-sm leading-relaxed text-charcoal/64"
          />
        )}
      </div>
    ) : (
      <div class="flex flex-col gap-1">
        {tier.showQuoteLabel !== false && (
          <EditableText
            id={customQuoteLabel.id}
            selector={customQuoteLabel.selector}
            kind={customQuoteLabel.kind}
            value={customQuoteLabel.value}
            as="p"
            class="pricing-quote js-pricing-custom-quote text-3xl text-charcoal"
          />
        )}
        <p
          aria-hidden="true"
          class:list={[
            'text-sm font-medium uppercase tracking-[0.06em]',
            tier.showQuoteLabel !== false ? 'invisible' : 'hidden',
          ]}
        >
          &nbsp;
        </p>
      </div>
    )}
  </div>

  <div class="flex flex-col">
    <EditableText
      {...includesLabel}
      as="p"
      class="text-[0.7rem] font-semibold uppercase tracking-[0.16em] text-ocean-blue/85"
    />
    <ul class="mt-3 grid gap-3 text-sm text-charcoal/72">
      {tier.features.map((feature, featureIndex) => (
        <li class="flex items-start gap-2.5">
          <span class="mt-2 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-ocean-blue"></span>
          <SharedPackageText
            packageKey={tier.key}
            field="feature"
            index={featureIndex}
            value={feature}
            kind="inline"
            as="span"
          />
        </li>
      ))}
    </ul>

    {tier.idealFor && (
      <div class="mt-6 border-t border-charcoal/10 pt-5">
        <EditableText
          {...idealForLabel}
          as="p"
          class="text-[0.7rem] font-semibold uppercase tracking-[0.16em] text-ocean-blue/85"
        />
        <SharedPackageText
          packageKey={tier.key}
          field="idealFor"
          value={tier.idealFor}
          kind="inline"
          as="p"
          class="mt-2 text-sm leading-relaxed text-charcoal/72"
        />
      </div>
    )}
  </div>

  <EditableLink
    {...cta}
    class="inline-flex w-full items-center justify-center self-end rounded-full bg-charcoal px-6 py-3 text-xs font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-ocean-blue"
  />
</article>
