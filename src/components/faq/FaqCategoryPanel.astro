---
import type { FAQCategory } from '../../lib/pageContent/faq';

interface Props {
  category: FAQCategory;
  categoryIndex: number;
}

const { category, categoryIndex } = Astro.props;
---

<div class="premium-panel p-5 sm:p-7">
  <h2 class="text-3xl text-charcoal">{category.title}</h2>
  <div class="mt-4 space-y-3">
    {category.items.map((item, itemIndex) => (
      <details
        class="group rounded-2xl border border-charcoal/10 bg-white/75 p-4"
        open={categoryIndex === 0 && itemIndex === 0}
      >
        <summary class="cursor-pointer list-none pr-8 text-sm font-semibold text-charcoal sm:text-base">
          {item.question}
        </summary>
        <p class="mt-3 text-sm leading-relaxed text-charcoal/72 sm:text-base">{item.answer}</p>
      </details>
    ))}
  </div>
</div>
