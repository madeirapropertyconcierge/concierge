---
import EditableText from '../cms/EditableText.astro';
import type { LegalSection } from '../../lib/pageContent/legal';

interface Props {
  section: LegalSection;
}

const { section } = Astro.props;
---

<article class="step-card">
  <EditableText {...section.title} as="h2" class="text-2xl text-charcoal" />
  <EditableText
    {...section.body}
    as="div"
    class="mt-2 text-sm leading-relaxed text-charcoal/72 sm:text-base"
  />

  {section.note && (
    <EditableText
      {...section.note}
      as="p"
      class="mt-3 text-xs font-semibold uppercase tracking-[0.08em] text-red-700"
    />
  )}
</article>
