<script>
  import { inject } from '@vercel/analytics';
  import {
    COOKIE_CONSENT_ACCEPTED_VALUE,
    COOKIE_CONSENT_CHANGED_EVENT,
    COOKIE_CONSENT_STORAGE_KEY,
  } from '../lib/cookieConsent';

  let analyticsInjected = false;

  const injectAnalytics = () => {
    if (analyticsInjected) {
      return;
    }

    analyticsInjected = true;
    inject({ framework: 'astro' });
  };

  const hasAcceptedConsent = () => {
    try {
      return localStorage.getItem(COOKIE_CONSENT_STORAGE_KEY) === COOKIE_CONSENT_ACCEPTED_VALUE;
    } catch {
      return false;
    }
  };

  if (hasAcceptedConsent()) {
    injectAnalytics();
  }

  window.addEventListener(COOKIE_CONSENT_CHANGED_EVENT, (event) => {
    if (event instanceof CustomEvent && event.detail === COOKIE_CONSENT_ACCEPTED_VALUE) {
      injectAnalytics();
    }
  });
</script>
