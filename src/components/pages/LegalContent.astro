---
import EditableText from '../cms/EditableText.astro';
import VisualPageLayout from './VisualPageLayout.astro';
import WhatsAppButton from '../WhatsAppButton.astro';
import LegalSectionCard from '../legal/LegalSectionCard.astro';
import { routeMap } from '../../i18n/routes';
import type { Locale } from '../../i18n/utils';
import { breadcrumbJsonLd } from '../../lib/seo';
import { madeiraImages } from '../../lib/madeiraImages';
import { SITE } from '../../lib/constants';
import { getLegalPageContent, type LegalPageType } from '../../lib/pageContent/legal';
import { getSiteChromeContent } from '../../lib/pageContent/siteChrome';

interface Props {
  lang: Locale;
  type: LegalPageType;
}

const { lang, type } = Astro.props;
const routes = routeMap[lang];

const hasLegalPlaceholders = [SITE.legal.legalName, SITE.legal.taxId, SITE.legal.commercialRegistry].some(
  (value) => value.includes('replace') || value.includes('XXXXX') || value.includes('XXXXXXXXX'),
);

const [page, siteChrome] = await Promise.all([
  getLegalPageContent(lang, type, {
    legalName: SITE.legal.legalName,
    taxId: SITE.legal.taxId,
    commercialRegistry: SITE.legal.commercialRegistry,
    email: SITE.email,
    phone: SITE.phone,
    address: SITE.address,
    complaintsBookUrl: SITE.legal.complaintsBookUrl,
    adrInfoUrl: SITE.legal.adrInfoUrl,
    termsHref: routes.terms,
    hasLegalPlaceholders,
  }),
  getSiteChromeContent(lang),
]);

const pageRoute = type === 'privacy' ? routes.privacy : routes.terms;

const pageSchema = [
  breadcrumbJsonLd([
    { name: siteChrome.nav.home, url: routes.home },
    { name: page.heroTitle.value, url: pageRoute },
  ]),
];
---

<VisualPageLayout
  lang={lang}
  title=""
  description=""
  heroEyebrow={page.heroEyebrow}
  heroTitle={page.heroTitle}
  heroSubtitle={page.heroSubtitle}
  heroImage={madeiraImages.yachtCoastline.src}
  heroAlt={madeiraImages.yachtCoastline.alt}
  heroPrimaryCta={page.primaryCta}
  heroSecondaryCta={page.secondaryCta}
  jsonLd={pageSchema}
>
  <section class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
    <div class="premium-panel p-6 sm:p-8 lg:p-10">
      <EditableText
        {...page.updatedLabel}
        as="p"
        class="text-xs uppercase tracking-[0.16em] text-charcoal/50"
      />

      <div class="mt-6 space-y-6">
        {page.sections.map((section) => <LegalSectionCard section={section} />)}
      </div>
    </div>
  </section>
</VisualPageLayout>

<WhatsAppButton lang={lang} />
