---
import EditableLink from '../cms/EditableLink.astro';
import EditableText from '../cms/EditableText.astro';
import VisualPageLayout from './VisualPageLayout.astro';
import WhatsAppButton from '../WhatsAppButton.astro';
import { routeMap } from '../../i18n/routes';
import type { Locale } from '../../i18n/utils';
import { breadcrumbJsonLd, articleJsonLd } from '../../lib/seo';
import { loadRequiredPageFields } from '../../lib/pageContent/cmsPageText';
import { getSiteChromeContent } from '../../lib/pageContent/siteChrome';

interface Props {
  lang: Locale;
  slug: string;
  title: string;
  excerpt: string;
  publishedAt: string;
  updatedAt?: string;
  coverImage: string;
  coverAlt: string;
  readingMinutes: number;
  body: string[];
  seo: {
    title: string;
    description: string;
    ogTitle: string;
    ogDescription: string;
    ogImage: string;
    canonical: string;
  };
}

const {
  lang,
  slug,
  title,
  excerpt,
  publishedAt,
  updatedAt,
  coverImage,
  coverAlt,
  readingMinutes,
  body,
  seo,
} = Astro.props;
const routes = routeMap[lang];

const [pageFields, siteChrome] = await Promise.all([
  loadRequiredPageFields('blog-post', lang, {
    texts: [
      'text:summary-title',
      'text:toc-title',
      'text:meta-published',
      'text:meta-updated',
      'text:meta-reading',
      'text:cta-title',
      'text:cta-body',
    ] as const,
    links: [
      'link:primary-cta',
      'link:secondary-cta',
    ] as const,
  }),
  getSiteChromeContent(lang),
]);

const formattedDate = new Date(publishedAt).toLocaleDateString(lang === 'pt' ? 'pt-PT' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const pagePath = `${routes.blog}/${slug}`;

const pageSchema = [
  breadcrumbJsonLd([
    { name: siteChrome.nav.home, url: routes.home },
    { name: pageFields.links['link:secondary-cta'].label, url: routes.blog },
    { name: title, url: pagePath },
  ]),
  articleJsonLd({
    headline: title,
    description: excerpt,
    path: pagePath,
    image: coverImage,
    datePublished: publishedAt,
    dateModified: updatedAt,
    inLanguage: lang === 'pt' ? 'pt-PT' : 'en-US',
  }),
];

type ContentBlock =
  | { type: 'h2'; text: string; id: string }
  | { type: 'h3'; text: string; id: string }
  | { type: 'p'; text: string }
  | { type: 'ul'; items: string[] }
  | { type: 'ol'; items: string[] };

const lines = body.map((entry) => entry.trim()).filter(Boolean);

function createAnchorId(value: string, index: number) {
  const normalized = value
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '');

  return `${normalized || 'section'}-${index}`;
}

const contentBlocks: ContentBlock[] = [];

for (let i = 0; i < lines.length; i += 1) {
  const line = lines[i];

  if (line.startsWith('## ')) {
    const text = line.slice(3).trim();
    contentBlocks.push({ type: 'h2', text, id: createAnchorId(text, i) });
    continue;
  }

  if (line.startsWith('### ')) {
    const text = line.slice(4).trim();
    contentBlocks.push({ type: 'h3', text, id: createAnchorId(text, i) });
    continue;
  }

  if (line.startsWith('- ')) {
    const items = [line.slice(2).trim()];
    while (i + 1 < lines.length && lines[i + 1].startsWith('- ')) {
      i += 1;
      items.push(lines[i].slice(2).trim());
    }
    contentBlocks.push({ type: 'ul', items });
    continue;
  }

  if (/^\d+\.\s/.test(line)) {
    const items = [line.replace(/^\d+\.\s/, '').trim()];
    while (i + 1 < lines.length && /^\d+\.\s/.test(lines[i + 1])) {
      i += 1;
      items.push(lines[i].replace(/^\d+\.\s/, '').trim());
    }
    contentBlocks.push({ type: 'ol', items });
    continue;
  }

  contentBlocks.push({ type: 'p', text: line });
}

const tableOfContents = contentBlocks.filter((block): block is Extract<ContentBlock, { type: 'h2' }> => block.type === 'h2');

const updatedLabel = updatedAt
  ? new Date(updatedAt).toLocaleDateString(lang === 'pt' ? 'pt-PT' : 'en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;
---

<VisualPageLayout
  lang={lang}
  title={seo.title || title}
  description={seo.description || excerpt}
  heroEyebrow={`${formattedDate} · ${readingMinutes} min`}
  heroTitle={title}
  heroSubtitle={excerpt}
  heroImage={{ src: coverImage, alt: coverAlt }}
  heroPrimaryCta={pageFields.links['link:primary-cta']}
  heroSecondaryCta={pageFields.links['link:secondary-cta']}
  ogImage={seo.ogImage || coverImage}
  canonicalUrl={seo.canonical}
  ogType="article"
  publishedTime={publishedAt}
  modifiedTime={updatedAt}
  jsonLd={pageSchema}
  useCmsSeo={false}
>
  <article class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
    <div class="grid gap-8 lg:grid-cols-[minmax(0,18rem)_minmax(0,1fr)] lg:gap-10">
      <aside class="space-y-5 lg:sticky lg:top-28 lg:h-fit">
        <div class="premium-panel p-5">
          <EditableText
            {...pageFields.texts['text:meta-published']}
            as="p"
            class="text-[0.63rem] font-semibold uppercase tracking-[0.16em] text-charcoal/55"
          />
          <p class="mt-2 text-sm font-medium text-charcoal/90">{formattedDate}</p>
          {updatedLabel && (
            <>
              <EditableText
                {...pageFields.texts['text:meta-updated']}
                as="p"
                class="mt-4 text-[0.63rem] font-semibold uppercase tracking-[0.16em] text-charcoal/55"
              />
              <p class="mt-2 text-sm font-medium text-charcoal/90">{updatedLabel}</p>
            </>
          )}
          <EditableText
            {...pageFields.texts['text:meta-reading']}
            as="p"
            class="mt-4 text-[0.63rem] font-semibold uppercase tracking-[0.16em] text-charcoal/55"
          />
          <p class="mt-2 text-sm font-medium text-charcoal/90">{readingMinutes} min</p>
        </div>

        {tableOfContents.length > 0 && (
          <nav class="premium-panel p-5">
            <EditableText
              {...pageFields.texts['text:toc-title']}
              as="p"
              class="text-[0.63rem] font-semibold uppercase tracking-[0.16em] text-charcoal/55"
            />
            <ul class="mt-4 space-y-2.5">
              {tableOfContents.map((section) => (
                <li>
                  <a href={`#${section.id}`} class="blog-toc-link">{section.text}</a>
                </li>
              ))}
            </ul>
          </nav>
        )}
      </aside>

      <div class="premium-panel p-6 sm:p-8 lg:p-12">
        <EditableText
          {...pageFields.texts['text:summary-title']}
          as="p"
          class="text-[0.63rem] font-semibold uppercase tracking-[0.16em] text-charcoal/55"
        />
        <p class="mt-3 text-base leading-relaxed text-charcoal/80">{excerpt}</p>

        <div class="blog-prose mt-10">
          {contentBlocks.map((block) => {
            if (block.type === 'h2') {
              return (
                <h2 id={block.id} class="scroll-mt-28">
                  {block.text}
                </h2>
              );
            }

            if (block.type === 'h3') {
              return (
                <h3 id={block.id} class="scroll-mt-28">
                  {block.text}
                </h3>
              );
            }

            if (block.type === 'ul') {
              return (
                <ul>
                  {block.items.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              );
            }

            if (block.type === 'ol') {
              return (
                <ol>
                  {block.items.map((item) => (
                    <li>{item}</li>
                  ))}
                </ol>
              );
            }

            return <p>{block.text}</p>;
          })}
        </div>
      </div>
    </div>
  </article>

  <section class="mx-auto max-w-4xl px-4 pb-20 sm:px-6 lg:px-8 lg:pb-24">
    <div class="premium-panel p-6 text-center sm:p-8">
      <EditableText {...pageFields.texts['text:cta-title']} as="h2" class="text-3xl text-charcoal sm:text-4xl" />
      <EditableText
        {...pageFields.texts['text:cta-body']}
        as="p"
        class="mx-auto mt-3 max-w-2xl text-sm leading-relaxed text-charcoal/72 sm:text-base"
      />
      <EditableLink
        {...pageFields.links['link:primary-cta']}
        class="mt-6 inline-flex items-center justify-center rounded-full bg-charcoal px-8 py-3 text-sm font-semibold uppercase tracking-[0.06em] text-white transition-colors hover:bg-ocean-blue"
      />
    </div>
  </section>
</VisualPageLayout>

<WhatsAppButton lang={lang} />
