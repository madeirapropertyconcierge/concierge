---
import VisualPageLayout from './VisualPageLayout.astro';
import WhatsAppButton from '../WhatsAppButton.astro';
import { t } from '../../i18n/utils';
import { routeMap } from '../../i18n/routes';
import type { Locale } from '../../i18n/utils';
import { breadcrumbJsonLd, articleJsonLd } from '../../lib/seo';

interface Props {
  lang: Locale;
  slug: string;
  title: string;
  excerpt: string;
  publishedAt: string;
  updatedAt?: string;
  coverImage: string;
  coverAlt: string;
  readingMinutes: number;
  body: string[];
}

const { lang, slug, title, excerpt, publishedAt, updatedAt, coverImage, coverAlt, readingMinutes, body } = Astro.props;
const routes = routeMap[lang];

const formattedDate = new Date(publishedAt).toLocaleDateString(lang === 'pt' ? 'pt-PT' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const pagePath = `${routes.blog}/${slug}`;

const pageSchema = [
  breadcrumbJsonLd([
    { name: 'Home', url: routes.home },
    { name: t(lang, 'nav.blog'), url: routes.blog },
    { name: title, url: pagePath },
  ]),
  articleJsonLd({
    headline: title,
    description: excerpt,
    path: pagePath,
    image: coverImage,
    datePublished: publishedAt,
    dateModified: updatedAt,
    inLanguage: lang === 'pt' ? 'pt-PT' : 'en-US',
  }),
];

type ContentBlock =
  | { type: 'h2'; text: string; id: string }
  | { type: 'h3'; text: string; id: string }
  | { type: 'p'; text: string }
  | { type: 'ul'; items: string[] }
  | { type: 'ol'; items: string[] };

const lines = body.map((entry) => entry.trim()).filter(Boolean);

function createAnchorId(value: string, index: number) {
  const normalized = value
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '');

  return `${normalized || 'section'}-${index}`;
}

const contentBlocks: ContentBlock[] = [];

for (let i = 0; i < lines.length; i += 1) {
  const line = lines[i];

  if (line.startsWith('## ')) {
    const text = line.slice(3).trim();
    contentBlocks.push({ type: 'h2', text, id: createAnchorId(text, i) });
    continue;
  }

  if (line.startsWith('### ')) {
    const text = line.slice(4).trim();
    contentBlocks.push({ type: 'h3', text, id: createAnchorId(text, i) });
    continue;
  }

  if (line.startsWith('- ')) {
    const items = [line.slice(2).trim()];
    while (i + 1 < lines.length && lines[i + 1].startsWith('- ')) {
      i += 1;
      items.push(lines[i].slice(2).trim());
    }
    contentBlocks.push({ type: 'ul', items });
    continue;
  }

  if (/^\d+\.\s/.test(line)) {
    const items = [line.replace(/^\d+\.\s/, '').trim()];
    while (i + 1 < lines.length && /^\d+\.\s/.test(lines[i + 1])) {
      i += 1;
      items.push(lines[i].replace(/^\d+\.\s/, '').trim());
    }
    contentBlocks.push({ type: 'ol', items });
    continue;
  }

  contentBlocks.push({ type: 'p', text: line });
}

const tableOfContents = contentBlocks.filter((block): block is Extract<ContentBlock, { type: 'h2' }> => block.type === 'h2');

const updatedLabel = updatedAt
  ? new Date(updatedAt).toLocaleDateString(lang === 'pt' ? 'pt-PT' : 'en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;

const copy =
  lang === 'pt'
    ? {
        heroEyebrow: `${formattedDate} · ${readingMinutes} min`,
        summaryTitle: 'Resumo Executivo',
        tocTitle: 'Neste artigo',
        metaPublished: 'Publicado',
        metaUpdated: 'Atualizado',
        metaReading: 'Leitura',
        ctaTitle: 'Quer aplicar isto ao seu imóvel?',
        ctaBody: 'Podemos montar e executar um plano operacional local para a sua situação.',
        ctaPrimary: 'Marcar Consulta',
      }
    : {
        heroEyebrow: `${formattedDate} · ${readingMinutes} min`,
        summaryTitle: 'Executive Summary',
        tocTitle: 'In This Article',
        metaPublished: 'Published',
        metaUpdated: 'Updated',
        metaReading: 'Reading Time',
        ctaTitle: 'Want help applying this to your property?',
        ctaBody: 'We can put together and run a local operating plan for your situation.',
        ctaPrimary: 'Book Consultation',
      };
---

<VisualPageLayout
  lang={lang}
  title={`${title} | ${t(lang, 'blog.title')}`}
  description={excerpt}
  heroEyebrow={copy.heroEyebrow}
  heroTitle={title}
  heroSubtitle={excerpt}
  heroImage={coverImage}
  heroAlt={coverAlt}
  heroPrimaryCta={{ label: copy.ctaPrimary, href: routes.contact }}
  heroSecondaryCta={{ label: t(lang, 'blog.backToBlog'), href: routes.blog }}
  ogType="article"
  publishedTime={publishedAt}
  modifiedTime={updatedAt}
  jsonLd={pageSchema}
>
  <article class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
    <div class="grid gap-8 lg:grid-cols-[minmax(0,18rem)_minmax(0,1fr)] lg:gap-10">
      <aside class="space-y-5 lg:sticky lg:top-28 lg:h-fit">
        <div class="premium-panel p-5">
          <p class="text-[0.63rem] font-semibold uppercase tracking-[0.16em] text-charcoal/55">{copy.metaPublished}</p>
          <p class="mt-2 text-sm font-medium text-charcoal/90">{formattedDate}</p>
          {updatedLabel && (
            <>
              <p class="mt-4 text-[0.63rem] font-semibold uppercase tracking-[0.16em] text-charcoal/55">{copy.metaUpdated}</p>
              <p class="mt-2 text-sm font-medium text-charcoal/90">{updatedLabel}</p>
            </>
          )}
          <p class="mt-4 text-[0.63rem] font-semibold uppercase tracking-[0.16em] text-charcoal/55">{copy.metaReading}</p>
          <p class="mt-2 text-sm font-medium text-charcoal/90">{readingMinutes} min</p>
        </div>

        {tableOfContents.length > 0 && (
          <nav class="premium-panel p-5">
            <p class="text-[0.63rem] font-semibold uppercase tracking-[0.16em] text-charcoal/55">{copy.tocTitle}</p>
            <ul class="mt-4 space-y-2.5">
              {tableOfContents.map((section) => (
                <li>
                  <a href={`#${section.id}`} class="blog-toc-link">{section.text}</a>
                </li>
              ))}
            </ul>
          </nav>
        )}
      </aside>

      <div class="premium-panel p-6 sm:p-8 lg:p-12">
        <p class="text-[0.63rem] font-semibold uppercase tracking-[0.16em] text-charcoal/55">{copy.summaryTitle}</p>
        <p class="mt-3 text-base leading-relaxed text-charcoal/80">{excerpt}</p>

        <div class="blog-prose mt-10">
          {contentBlocks.map((block) => {
            if (block.type === 'h2') {
              return (
                <h2 id={block.id} class="scroll-mt-28">
                  {block.text}
                </h2>
              );
            }

            if (block.type === 'h3') {
              return (
                <h3 id={block.id} class="scroll-mt-28">
                  {block.text}
                </h3>
              );
            }

            if (block.type === 'ul') {
              return (
                <ul>
                  {block.items.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              );
            }

            if (block.type === 'ol') {
              return (
                <ol>
                  {block.items.map((item) => (
                    <li>{item}</li>
                  ))}
                </ol>
              );
            }

            return <p>{block.text}</p>;
          })}
        </div>
      </div>
    </div>
  </article>

  <section class="mx-auto max-w-4xl px-4 pb-20 sm:px-6 lg:px-8 lg:pb-24">
    <div class="premium-panel p-6 text-center sm:p-8">
      <h2 class="text-3xl text-charcoal sm:text-4xl">{copy.ctaTitle}</h2>
      <p class="mx-auto mt-3 max-w-2xl text-sm leading-relaxed text-charcoal/72 sm:text-base">{copy.ctaBody}</p>
      <a href={routes.contact} class="mt-6 inline-flex items-center justify-center rounded-full bg-charcoal px-8 py-3 text-sm font-semibold uppercase tracking-[0.06em] text-white transition-colors hover:bg-ocean-blue">{copy.ctaPrimary}</a>
    </div>
  </section>
</VisualPageLayout>

<WhatsAppButton lang={lang} />
