---
import EditableImage from '../cms/EditableImage.astro';
import EditableLink from '../cms/EditableLink.astro';
import EditableText from '../cms/EditableText.astro';
import WhatsAppButton from '../WhatsAppButton.astro';
import Testimonials from '../sections/Testimonials.astro';
import SharedPackageText from '../cms/SharedPackageText.astro';
import type { Locale } from '../../i18n/utils';
import { routeMap } from '../../i18n/routes';
import { getHomepageContent } from '../../lib/homepageContent';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const routes = routeMap[lang];
const copy = await getHomepageContent(lang);
---

<div class="relative overflow-hidden">
  <div class="absolute inset-0 -z-20 bg-[radial-gradient(circle_at_18%_12%,rgba(247,180,94,0.18),transparent_45%),radial-gradient(circle_at_82%_14%,rgba(28,96,120,0.15),transparent_42%),linear-gradient(180deg,#f6f4ef_0%,#edf1f3_65%,#f6f4ef_100%)]"></div>

  <section class="relative isolate overflow-hidden px-4 pb-16 pt-8 sm:px-6 lg:px-8 lg:pb-24 lg:pt-10">
    <EditableImage
      {...copy.heroBackground}
      class="absolute inset-0 -z-20 h-full w-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 -z-10 bg-[linear-gradient(112deg,rgba(8,21,30,0.78)_0%,rgba(8,21,30,0.52)_48%,rgba(8,21,30,0.74)_100%)]"></div>
    <div class="hero-fade absolute inset-x-0 bottom-0 -z-10 h-52"></div>

    <div class="mx-auto grid max-w-7xl items-end gap-10 pt-12 lg:grid-cols-[1.05fr_0.95fr] lg:pt-16">
      <div class="reveal space-y-7 text-white">
        <EditableText
          {...copy.heroBadge}
          as="p"
          class="inline-flex rounded-full border border-white/25 bg-white/12 px-4 py-2 text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-white/85 backdrop-blur"
        />

        <EditableText
          {...copy.heroTitle}
          as="h1"
          class="max-w-3xl text-balance font-serif text-5xl leading-[1.05] tracking-tight text-white sm:text-6xl xl:text-7xl"
        />

        <EditableText
          {...copy.heroSubtitle}
          as="p"
          class="max-w-2xl text-base leading-relaxed text-white/82 sm:text-lg"
        />

        <div class="flex flex-col gap-3 pt-2 sm:flex-row sm:items-center">
          <EditableLink
            {...copy.heroPrimaryCta}
            class="inline-flex items-center justify-center rounded-full bg-golden-sand px-7 py-3 text-sm font-semibold uppercase tracking-[0.06em] text-charcoal transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_14px_30px_rgba(247,180,94,0.35)]"
          />
          <EditableLink
            {...copy.heroSecondaryCta}
            class="inline-flex items-center justify-center rounded-full border border-white/30 bg-white/10 px-7 py-3 text-sm font-semibold uppercase tracking-[0.06em] text-white backdrop-blur transition-all duration-300 hover:bg-white/20"
          />
        </div>

        <div class="grid max-w-xl grid-cols-3 gap-3 pt-4">
          {copy.trustSignals.map((signal) => (
            <div class="premium-glass px-3 py-3 text-center" data-animate="stagger">
              <EditableText {...signal.value} as="p" class="text-lg font-bold text-white" />
              <EditableText
                {...signal.label}
                as="p"
                class="text-xs uppercase tracking-[0.09em] text-white/75"
              />
            </div>
          ))}
        </div>
      </div>

      <div class="reveal reveal-delay-1 grid gap-4 sm:grid-cols-2">
        <article class="media-card sm:col-span-2">
          <EditableImage
            {...copy.mediaCards[0].image}
            class="h-full w-full object-cover"
            loading="eager"
          />
          <EditableText {...copy.mediaCards[0].caption} as="div" class="media-card-caption" />
        </article>

        <article class="media-card aspect-[4/5]">
          <EditableImage
            {...copy.mediaCards[1].image}
            class="h-full w-full object-cover"
            loading="lazy"
          />
          <EditableText {...copy.mediaCards[1].caption} as="div" class="media-card-caption" />
        </article>

        <article class="media-card aspect-[4/5]">
          <EditableImage
            {...copy.mediaCards[2].image}
            class="h-full w-full object-cover"
            loading="lazy"
          />
          <EditableText {...copy.mediaCards[2].caption} as="div" class="media-card-caption" />
        </article>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
    <div class="mb-10 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-2xl">
        <EditableText
          {...copy.architectureEyebrow}
          as="h2"
          class="text-4xl leading-[1.05] text-charcoal sm:text-5xl"
        />
        <EditableText
          {...copy.architectureTitle}
          as="p"
          class="mt-4 text-base leading-relaxed text-charcoal/75 sm:text-lg"
        />
      </div>
      <EditableLink {...copy.architectureLink} class="link-chip w-fit" />
    </div>

    <div class="grid gap-6 lg:grid-cols-12">
      {copy.serviceTiles.map((tile, index) => (
        <a
          href={routes[tile.hrefKey]}
          class:list={[
            'service-tile reveal h-[18rem] sm:h-[22rem] lg:h-[24rem]',
            tile.span,
            index > 0 ? 'reveal-delay-1' : '',
          ]}
        >
          <img src={tile.image} alt={tile.alt} class="h-full w-full object-cover" loading="lazy" />
          <div class="service-overlay">
            <SharedPackageText
              packageKey={tile.packageKey}
              field="title"
              value={tile.title}
              kind="inline"
              as="h3"
              class="text-2xl text-white sm:text-3xl"
            />
            <SharedPackageText
              packageKey={tile.packageKey}
              field="homeBlurb"
              value={tile.blurb}
              kind="inline"
              as="p"
              class="text-sm text-white/82 sm:text-base"
            />
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8 lg:pb-24">
    <div class="premium-panel p-6 sm:p-8 lg:p-10">
      <div class="mb-8 flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <EditableText {...copy.processEyebrow} as="p" class="eyebrow" />
          <EditableText
            {...copy.processTitle}
            as="h2"
            class="mt-2 text-4xl leading-[1.05] text-charcoal sm:text-5xl"
          />
        </div>
        <EditableLink {...copy.processLink} class="link-chip w-fit" />
      </div>

      <div class="max-w-3xl space-y-5">
        <EditableText
          {...copy.processBody}
          as="p"
          class="text-base leading-relaxed text-charcoal/75 sm:text-lg whitespace-pre-line"
        />
        <EditableText
          {...copy.processChecklist}
          as="p"
          class="text-base font-semibold leading-loose text-charcoal whitespace-pre-line"
        />
        <EditableText
          {...copy.processClosing}
          as="p"
          class="text-base leading-relaxed text-charcoal/75 sm:text-lg"
        />
      </div>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <EditableLink
          {...copy.processPrimaryCta}
          class="inline-flex items-center justify-center rounded-full bg-golden-sand px-7 py-3 text-sm font-semibold uppercase tracking-[0.06em] text-charcoal transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_14px_30px_rgba(247,180,94,0.35)]"
        />
        <EditableLink
          {...copy.processSecondaryCta}
          class="inline-flex items-center justify-center rounded-full border border-charcoal/20 bg-white px-7 py-3 text-sm font-semibold uppercase tracking-[0.06em] text-charcoal transition-all duration-300 hover:bg-charcoal/5"
        />
      </div>

      <div class="mt-10 grid gap-5 md:grid-cols-3">
        {copy.steps.map((item, index) => (
          <article class:list={['step-card reveal', index > 0 ? 'reveal-delay-1' : '']}>
            <p class="step-index">{item.step}</p>
            <EditableText {...item.title} as="h3" class="mt-3 text-2xl text-charcoal" />
            <EditableText
              {...item.detail}
              as="p"
              class="mt-2 text-sm leading-relaxed text-charcoal/72"
            />
          </article>
        ))}
      </div>
    </div>
  </section>

  <Testimonials lang={lang} />

  <section class="relative isolate overflow-hidden px-4 pb-20 sm:px-6 lg:px-8 lg:pb-24">
    <EditableImage
      {...copy.finalBackground}
      class="absolute inset-0 -z-20 h-full w-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 -z-10 bg-[linear-gradient(100deg,rgba(11,24,30,0.87)_0%,rgba(11,24,30,0.67)_55%,rgba(11,24,30,0.83)_100%)]"></div>

    <div class="mx-auto max-w-4xl px-4 py-16 text-center text-white sm:px-6 lg:py-20">
      <EditableText
        {...copy.finalEyebrow}
        as="p"
        class="eyebrow !border-white/35 !bg-white/10 !text-white/80"
      />
      <EditableText
        {...copy.finalTitle}
        as="h2"
        class="mt-5 text-balance text-4xl leading-[1.05] text-white sm:text-5xl lg:text-6xl"
      />
      <EditableText
        {...copy.finalSubtitle}
        as="p"
        class="mx-auto mt-5 max-w-2xl text-base leading-relaxed text-white/80 sm:text-lg"
      />

      <div class="mt-9 flex flex-col justify-center gap-3 sm:flex-row">
        <EditableLink
          {...copy.finalPrimaryCta}
          class="inline-flex items-center justify-center rounded-full bg-white px-8 py-3 text-sm font-semibold uppercase tracking-[0.06em] text-charcoal transition-all duration-300 hover:-translate-y-0.5 hover:bg-golden-sand"
        />
        <EditableLink
          {...copy.finalSecondaryCta}
          class="inline-flex items-center justify-center rounded-full border border-white/35 bg-white/8 px-8 py-3 text-sm font-semibold uppercase tracking-[0.06em] text-white backdrop-blur transition-colors hover:bg-white/20"
        />
      </div>
    </div>
  </section>
</div>

<WhatsAppButton lang={lang} />
