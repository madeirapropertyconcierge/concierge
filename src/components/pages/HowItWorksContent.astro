---
import EditableLink from '../cms/EditableLink.astro';
import EditableText from '../cms/EditableText.astro';
import VisualPageLayout from './VisualPageLayout.astro';
import WhatsAppButton from '../WhatsAppButton.astro';
import { routeMap } from '../../i18n/routes';
import type { Locale } from '../../i18n/utils';
import { breadcrumbJsonLd } from '../../lib/seo';
import { madeiraImages } from '../../lib/madeiraImages';
import { loadRequiredPageFields } from '../../lib/pageContent/cmsPageText';
import { getSiteChromeContent } from '../../lib/pageContent/siteChrome';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const routes = routeMap[lang];
const pageId = lang === 'en' ? 'en-how-it-works' : 'pt-como-funciona';

const [pageFields, siteChrome] = await Promise.all([
  loadRequiredPageFields(pageId, lang, {
    texts: [
      'text:hero-eyebrow',
      'text:hero-title',
      'text:hero-subtitle',
      'text:step-1-title',
      'text:step-1-description',
      'text:step-2-title',
      'text:step-2-description',
      'text:step-3-title',
      'text:step-3-description',
      'text:step-4-title',
      'text:step-4-description',
      'text:deliverables-title',
      'text:deliverable-1',
      'text:deliverable-3',
      'text:deliverable-4',
      'text:deliverable-5',
      'text:media-caption',
      'text:timeline-title',
      'text:timeline-range-1',
      'text:timeline-text-1',
      'text:timeline-range-2',
      'text:timeline-text-2',
      'text:timeline-range-3',
      'text:timeline-text-3',
      'text:timeline-range-4',
      'text:timeline-text-4',
      'text:timeline-range-5',
      'text:timeline-text-5',
      'text:cta-title',
      'text:cta-body',
    ] as const,
    links: [
      'link:primary-cta',
      'link:secondary-cta',
    ] as const,
  }),
  getSiteChromeContent(lang),
]);

const howToSteps = [
  {
    title: pageFields.texts['text:step-1-title'],
    description: pageFields.texts['text:step-1-description'],
  },
  {
    title: pageFields.texts['text:step-2-title'],
    description: pageFields.texts['text:step-2-description'],
  },
  {
    title: pageFields.texts['text:step-3-title'],
    description: pageFields.texts['text:step-3-description'],
  },
  {
    title: pageFields.texts['text:step-4-title'],
    description: pageFields.texts['text:step-4-description'],
  },
] as const;

const pageSchema = [
  breadcrumbJsonLd([
    { name: siteChrome.nav.home, url: routes.home },
    { name: pageFields.texts['text:hero-title'].value, url: routes.howItWorks },
  ]),
  {
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: pageFields.texts['text:hero-title'].value,
    description: pageFields.texts['text:hero-subtitle'].value,
    step: howToSteps.map((step, index) => ({
      '@type': 'HowToStep',
      position: index + 1,
      name: step.title.value,
      text: step.description.value,
    })),
  },
];
---

<VisualPageLayout
  lang={lang}
  title=""
  description=""
  heroEyebrow={pageFields.texts['text:hero-eyebrow']}
  heroTitle={pageFields.texts['text:hero-title']}
  heroSubtitle={pageFields.texts['text:hero-subtitle']}
  heroImage={madeiraImages.pontaHikers.src}
  heroAlt={madeiraImages.pontaHikers.alt}
  heroPrimaryCta={pageFields.links['link:primary-cta']}
  heroSecondaryCta={pageFields.links['link:secondary-cta']}
  jsonLd={pageSchema}
>
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
    <div class="grid gap-5 md:grid-cols-2">
      {howToSteps.map((step, index) => (
        <article class:list={['step-card reveal', index > 0 ? 'reveal-delay-1' : '']}>
          <p class="step-index">{`0${index + 1}`}</p>
          <EditableText {...step.title} as="h2" class="mt-3 text-3xl text-charcoal" />
          <EditableText {...step.description} as="p" class="mt-3 text-sm leading-relaxed text-charcoal/72 sm:text-base" />
        </article>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8 lg:pb-24">
    <div class="grid gap-8 lg:grid-cols-[1.05fr_0.95fr] lg:items-start">
      <div class="premium-panel p-6 sm:p-8 lg:p-10">
        <EditableText {...pageFields.texts['text:deliverables-title']} as="p" class="eyebrow" />
        <ul class="mt-6 space-y-3">
          {[
            pageFields.texts['text:deliverable-1'],
            pageFields.texts['text:deliverable-3'],
            pageFields.texts['text:deliverable-4'],
            pageFields.texts['text:deliverable-5'],
          ].map((item) => (
            <li class="flex items-start gap-3 text-sm text-charcoal/75 sm:text-base">
              <span class="mt-2 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-ocean-blue"></span>
              <EditableText {...item} as="span" />
            </li>
          ))}
        </ul>
      </div>

      <article class="media-card reveal reveal-delay-1 min-h-[20rem]">
        <img src={madeiraImages.tobogganRideFunchal.src} alt={madeiraImages.tobogganRideFunchal.alt} class="h-full w-full object-cover" loading="lazy" />
        <EditableText {...pageFields.texts['text:media-caption']} as="div" class="media-card-caption" />
      </article>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-4 pb-20 sm:px-6 lg:px-8 lg:pb-24">
    <div class="premium-panel p-6 sm:p-8">
      <EditableText {...pageFields.texts['text:timeline-title']} as="p" class="eyebrow" />
      <div class="mt-6 grid gap-4">
        {[
          [pageFields.texts['text:timeline-range-1'], pageFields.texts['text:timeline-text-1']],
          [pageFields.texts['text:timeline-range-2'], pageFields.texts['text:timeline-text-2']],
          [pageFields.texts['text:timeline-range-3'], pageFields.texts['text:timeline-text-3']],
          [pageFields.texts['text:timeline-range-4'], pageFields.texts['text:timeline-text-4']],
          [pageFields.texts['text:timeline-range-5'], pageFields.texts['text:timeline-text-5']],
        ].map(([range, text]) => (
          <article class="step-card">
            <EditableText {...range} as="p" class="step-index" />
            <EditableText
              {...text}
              as="p"
              class="mt-3 text-sm leading-relaxed text-charcoal/75 sm:text-base"
            />
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="relative isolate overflow-hidden px-4 pb-20 sm:px-6 lg:px-8 lg:pb-24">
    <img
      src={madeiraImages.funchalBayBoats.src}
      alt={madeiraImages.funchalBayBoats.alt}
      class="absolute inset-0 -z-20 h-full w-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 -z-10 bg-[linear-gradient(100deg,rgba(11,24,30,0.87)_0%,rgba(11,24,30,0.67)_55%,rgba(11,24,30,0.83)_100%)]"></div>

    <div class="mx-auto max-w-4xl px-4 py-14 text-center text-white sm:px-6 lg:py-20">
      <EditableText
        {...pageFields.texts['text:cta-title']}
        as="h2"
        class="text-balance text-4xl leading-[1.05] text-white sm:text-5xl"
      />
      <EditableText
        {...pageFields.texts['text:cta-body']}
        as="p"
        class="mx-auto mt-5 max-w-2xl text-base leading-relaxed text-white/80 sm:text-lg"
      />
      <EditableLink
        {...pageFields.links['link:primary-cta']}
        class="mt-8 inline-flex items-center justify-center rounded-full bg-white px-8 py-3 text-sm font-semibold uppercase tracking-[0.06em] text-charcoal transition-colors hover:bg-golden-sand"
      />
    </div>
  </section>
</VisualPageLayout>

<WhatsAppButton lang={lang} />
