---
import VisualPageLayout from './VisualPageLayout.astro';
import WhatsAppButton from '../WhatsAppButton.astro';
import { t } from '../../i18n/utils';
import { routeMap } from '../../i18n/routes';
import type { Locale } from '../../i18n/utils';
import { breadcrumbJsonLd } from '../../lib/seo';
import { madeiraImages } from '../../lib/madeiraImages';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const routes = routeMap[lang];

const steps = ['step1', 'step2', 'step3', 'step4'] as const;

const copy =
  lang === 'pt'
    ? {
        heroEyebrow: 'Método Operacional',
        heroTitle: 'Um processo claro para proprietários que gerem à distância.',
        heroSubtitle:
          'Do primeiro diagnóstico à rotina mensal, cada etapa foi desenhada para reduzir risco e aumentar previsibilidade.',
        deliverablesTitle: 'Entregáveis contínuos',
        deliverables: [
          'Relatório mensal com ocupação, receita, despesas e manutenção',
          'Checklist de limpeza de 56 pontos com prova fotográfica',
          'Registo de ocorrências e próximos passos com responsáveis definidos',
          'SLA: resposta ao proprietário em até 4h úteis; situações urgentes recebem prioridade reforçada nos pacotes Premium Care e Revenue & Hosting',
          'Comunicação única via WhatsApp e atualizações em decisões críticas',
        ],
        mediaCaption: 'Visibilidade Operacional',
        timelineTitle: 'Primeiros 30 dias (onboarding)',
        timeline: [
          { range: 'Dia 1–3', text: 'Chamada de diagnóstico e definição do pacote mais adequado.' },
          { range: 'Dia 4–10', text: 'Auditoria do imóvel: condição, riscos, conformidade e prioridades.' },
          { range: 'Dia 11–20', text: 'Ativação de fornecedores, SOPs e templates de comunicação.' },
          { range: 'Dia 21–30', text: 'Operação ativa com primeiro relatório mensal e log de manutenção.' },
        ],
        ctaTitle: 'O seu imóvel deve funcionar com sistema, não com surpresas.',
        ctaBody: 'Comece com uma chamada de diagnóstico e mostramos como funciona o dia-a-dia.',
        ctaPrimary: 'Marcar Chamada de Diagnóstico',
      }
    : {
        heroEyebrow: 'Operating Method',
        heroTitle: 'A clear process for overseas owners.',
        heroSubtitle:
          'From first diagnostic to monthly rhythm, each phase is designed to reduce risk and improve predictability.',
        deliverablesTitle: 'What you receive consistently',
        deliverables: [
          'Monthly owner report with occupancy, revenue, costs, and maintenance',
          '56-point turnover cleaning checklist with photo proof',
          'Maintenance and issue log with clear next actions',
          'SLA targets: owner response within 4 business hours; urgent issues receive faster escalation on Premium Care and Revenue & Hosting',
          'Single WhatsApp contact plus updates on critical decisions',
        ],
        mediaCaption: 'Operational Visibility',
        timelineTitle: 'Your first 30 days (onboarding)',
        timeline: [
          { range: 'Day 1–3', text: 'Diagnostic call and package fit.' },
          { range: 'Day 4–10', text: 'Property audit: condition, risk, compliance, and priorities.' },
          { range: 'Day 11–20', text: 'Vendor activation, SOP setup, and communication templates.' },
          { range: 'Day 21–30', text: 'Go-live with first monthly report and maintenance log.' },
        ],
        ctaTitle: 'Your property should run on a system, not on surprises.',
        ctaBody: 'Start with a diagnostic call and we\'ll show you what the day-to-day looks like.',
        ctaPrimary: 'Book Diagnostic Call',
      };

const pageSchema = [
  breadcrumbJsonLd([
    { name: 'Home', url: routes.home },
    { name: t(lang, 'nav.howItWorks'), url: routes.howItWorks },
  ]),
  {
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: t(lang, 'howItWorks.hero.title'),
    description: t(lang, 'howItWorks.metaDescription'),
    step: steps.map((step, index) => ({
      '@type': 'HowToStep',
      position: index + 1,
      name: t(lang, `howItWorks.steps.${step}.title`),
      text: t(lang, `howItWorks.steps.${step}.description`),
    })),
  },
];
---

<VisualPageLayout
  lang={lang}
  title={t(lang, 'howItWorks.metaTitle')}
  description={t(lang, 'howItWorks.metaDescription')}
  heroEyebrow={copy.heroEyebrow}
  heroTitle={copy.heroTitle}
  heroSubtitle={copy.heroSubtitle}
  heroImage={madeiraImages.pontaHikers.src}
  heroAlt={madeiraImages.pontaHikers.alt}
  heroPrimaryCta={{ label: copy.ctaPrimary, href: routes.contact }}
  heroSecondaryCta={{ label: t(lang, 'nav.pricing'), href: routes.pricing }}
  jsonLd={pageSchema}
>
  <section data-cms-ignore="all" class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
    <div class="grid gap-5 md:grid-cols-2">
      {steps.map((step, index) => (
        <article class:list={['step-card reveal', index > 0 ? 'reveal-delay-1' : '']}>
          <p class="step-index">{`0${index + 1}`}</p>
          <h2 class="mt-3 text-3xl text-charcoal">{t(lang, `howItWorks.steps.${step}.title`)}</h2>
          <p class="mt-3 text-sm leading-relaxed text-charcoal/72 sm:text-base">{t(lang, `howItWorks.steps.${step}.description`)}</p>
        </article>
      ))}
    </div>
  </section>

  <section data-cms-ignore="all" class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8 lg:pb-24">
    <div class="grid gap-8 lg:grid-cols-[1.05fr_0.95fr] lg:items-start">
      <div class="premium-panel p-6 sm:p-8 lg:p-10">
        <p class="eyebrow">{copy.deliverablesTitle}</p>
        <ul class="mt-6 space-y-3">
          {copy.deliverables.map((item) => (
            <li class="flex items-start gap-3 text-sm text-charcoal/75 sm:text-base">
              <span class="mt-2 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-ocean-blue"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <article class="media-card reveal reveal-delay-1 min-h-[20rem]">
        <img src={madeiraImages.tobogganRideFunchal.src} alt={madeiraImages.tobogganRideFunchal.alt} class="h-full w-full object-cover" loading="lazy" />
        <div class="media-card-caption">{copy.mediaCaption}</div>
      </article>
    </div>
  </section>

  <section data-cms-ignore="all" class="mx-auto max-w-5xl px-4 pb-20 sm:px-6 lg:px-8 lg:pb-24">
    <div class="premium-panel p-6 sm:p-8">
      <p class="eyebrow">{copy.timelineTitle}</p>
      <div class="mt-6 grid gap-4">
        {copy.timeline.map((item, index) => (
          <article class="step-card">
            <p class="step-index">{item.range}</p>
            <p class="mt-3 text-sm leading-relaxed text-charcoal/75 sm:text-base">{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section data-cms-ignore="all" class="relative isolate overflow-hidden px-4 pb-20 sm:px-6 lg:px-8 lg:pb-24">
    <img
      src={madeiraImages.funchalBayBoats.src}
      alt={madeiraImages.funchalBayBoats.alt}
      class="absolute inset-0 -z-20 h-full w-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 -z-10 bg-[linear-gradient(100deg,rgba(11,24,30,0.87)_0%,rgba(11,24,30,0.67)_55%,rgba(11,24,30,0.83)_100%)]"></div>

    <div class="mx-auto max-w-4xl px-4 py-14 text-center text-white sm:px-6 lg:py-20">
      <h2 class="text-balance text-4xl leading-[1.05] text-white sm:text-5xl">{copy.ctaTitle}</h2>
      <p class="mx-auto mt-5 max-w-2xl text-base leading-relaxed text-white/80 sm:text-lg">{copy.ctaBody}</p>
      <a href={routes.contact} class="mt-8 inline-flex items-center justify-center rounded-full bg-white px-8 py-3 text-sm font-semibold uppercase tracking-[0.06em] text-charcoal transition-colors hover:bg-golden-sand">{copy.ctaPrimary}</a>
    </div>
  </section>
</VisualPageLayout>

<WhatsAppButton lang={lang} />
