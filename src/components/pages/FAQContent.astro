---
import EditableLink from '../cms/EditableLink.astro';
import EditableText from '../cms/EditableText.astro';
import VisualPageLayout from './VisualPageLayout.astro';
import WhatsAppButton from '../WhatsAppButton.astro';
import FaqCategoryPanel from '../faq/FaqCategoryPanel.astro';
import { routeMap } from '../../i18n/routes';
import type { Locale } from '../../i18n/utils';
import { breadcrumbJsonLd } from '../../lib/seo';
import { madeiraImages } from '../../lib/madeiraImages';
import { getFaqPageContent } from '../../lib/pageContent/faq';
import { getSiteChromeContent } from '../../lib/pageContent/siteChrome';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const routes = routeMap[lang];
const [copy, siteChrome] = await Promise.all([
  getFaqPageContent(lang),
  getSiteChromeContent(lang),
]);
const faqItemsFlat = copy.categories.flatMap((category) => category.items);

const pageSchema = [
  breadcrumbJsonLd([
    { name: siteChrome.nav.home, url: routes.home },
    { name: siteChrome.nav.faq, url: routes.faq },
  ]),
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItemsFlat.map((item) => ({
      '@type': 'Question',
      name: item.question.value,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.answer.value,
      },
    })),
  },
];
---

<VisualPageLayout
  lang={lang}
  title=""
  description=""
  heroEyebrow={copy.heroEyebrow}
  heroTitle={copy.heroTitle}
  heroSubtitle={copy.heroSubtitle}
  heroImage={madeiraImages.fruitMarketStalls.src}
  heroAlt={madeiraImages.fruitMarketStalls.alt}
  heroPrimaryCta={copy.heroPrimaryCta}
  heroSecondaryCta={copy.heroSecondaryCta}
  jsonLd={pageSchema}
>
  <section class="mx-auto max-w-5xl px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
    <div class="space-y-8">
      {copy.categories.map((category, categoryIndex) => (
        <FaqCategoryPanel category={category} categoryIndex={categoryIndex} />
      ))}
    </div>
  </section>

  <section class="relative isolate overflow-hidden px-4 pb-20 sm:px-6 lg:px-8 lg:pb-24">
    <img src={madeiraImages.machicoFireFestival.src} alt={madeiraImages.machicoFireFestival.alt} class="absolute inset-0 -z-20 h-full w-full object-cover" loading="lazy" />
    <div class="absolute inset-0 -z-10 bg-[linear-gradient(100deg,rgba(11,24,30,0.87)_0%,rgba(11,24,30,0.67)_55%,rgba(11,24,30,0.83)_100%)]"></div>

    <div class="mx-auto max-w-4xl px-4 py-14 text-center text-white sm:px-6 lg:py-20">
      <EditableText
        {...copy.closingTitle}
        as="h2"
        class="text-balance text-4xl leading-[1.05] text-white sm:text-5xl"
      />
      <EditableText
        {...copy.closingBody}
        as="p"
        class="mx-auto mt-4 max-w-2xl text-base leading-relaxed text-white/80 sm:text-lg"
      />
      <EditableLink
        {...copy.closingCta}
        class="mt-8 inline-flex items-center justify-center rounded-full bg-white px-8 py-3 text-sm font-semibold uppercase tracking-[0.06em] text-charcoal transition-colors hover:bg-golden-sand"
      />
    </div>
  </section>
</VisualPageLayout>

<WhatsAppButton lang={lang} />
