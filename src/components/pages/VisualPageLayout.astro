---
import EditableImage from '../cms/EditableImage.astro';
import EditableLink from '../cms/EditableLink.astro';
import EditableText from '../cms/EditableText.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import type {
  CmsPageImageValue,
  CmsPageLinkValue,
  CmsPageTextValue,
} from '../../lib/pageContent/cmsPageText';
import type { Locale } from '../../i18n/utils';

type RenderableText = string | CmsPageTextValue;
type RenderableLink = { label: string; href: string } | CmsPageLinkValue;
type RenderableImage = string | { src: string; alt: string } | CmsPageImageValue;

interface Props {
  lang: Locale;
  title: string;
  description: string;
  heroTitle: RenderableText;
  heroSubtitle: RenderableText;
  heroImage: RenderableImage;
  heroAlt?: string;
  heroEyebrow?: RenderableText;
  heroPrimaryCta?: RenderableLink;
  heroSecondaryCta?: RenderableLink;
  ogImage?: string;
  canonicalUrl?: string;
  noindex?: boolean;
  useCmsSeo?: boolean;
  ogType?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  lang,
  title,
  description,
  heroTitle,
  heroSubtitle,
  heroImage,
  heroAlt = '',
  heroEyebrow,
  heroPrimaryCta,
  heroSecondaryCta,
  ogImage = typeof heroImage === 'string' ? heroImage : heroImage.src,
  canonicalUrl,
  noindex = false,
  useCmsSeo = true,
  ogType = 'website',
  publishedTime,
  modifiedTime,
  jsonLd,
} = Astro.props;

function isCmsTextValue(value: RenderableText | undefined): value is CmsPageTextValue {
  return typeof value === 'object' && value !== null && 'kind' in value;
}

function isCmsLinkValue(value: RenderableLink | undefined): value is CmsPageLinkValue {
  return typeof value === 'object' && value !== null && 'selector' in value;
}

function isCmsImageValue(value: Exclude<RenderableImage, string>): value is CmsPageImageValue {
  return typeof value === 'object' && value !== null && 'selector' in value;
}
---

<BaseLayout
  title={title}
  description={description}
  lang={lang}
  ogImage={ogImage}
  canonicalUrl={canonicalUrl}
  noindex={noindex}
  useCmsSeo={useCmsSeo}
  ogType={ogType}
  publishedTime={publishedTime}
  modifiedTime={modifiedTime}
  jsonLd={jsonLd}
>
  <div class="relative overflow-hidden">
    <div class="absolute inset-0 -z-20 bg-[radial-gradient(circle_at_12%_8%,rgba(247,180,94,0.14),transparent_40%),radial-gradient(circle_at_87%_18%,rgba(42,95,125,0.14),transparent_36%),linear-gradient(180deg,#f6f4ef_0%,#edf1f3_68%,#f6f4ef_100%)]"></div>

    <section class="relative isolate overflow-hidden px-4 pb-16 pt-8 sm:px-6 lg:px-8 lg:pb-20 lg:pt-10">
      {typeof heroImage === 'string' ? (
        <img
          src={heroImage}
          alt={heroAlt}
          class="absolute inset-0 -z-20 h-full w-full object-cover"
          loading="eager"
        />
      ) : isCmsImageValue(heroImage) ? (
        <EditableImage
          {...heroImage}
          class="absolute inset-0 -z-20 h-full w-full object-cover"
          loading="eager"
        />
      ) : (
        <img
          src={heroImage.src}
          alt={heroImage.alt}
          class="absolute inset-0 -z-20 h-full w-full object-cover"
          loading="eager"
        />
      )}
      <div class="absolute inset-0 -z-10 bg-[linear-gradient(110deg,rgba(8,21,30,0.83)_0%,rgba(8,21,30,0.62)_47%,rgba(8,21,30,0.82)_100%)]"></div>
      <div class="hero-fade absolute inset-x-0 bottom-0 -z-10 h-40"></div>

      <div class="mx-auto max-w-7xl py-14 lg:py-16">
        <div class="reveal max-w-3xl text-white">
          {heroEyebrow && (
            isCmsTextValue(heroEyebrow) ? (
              <EditableText
                {...heroEyebrow}
                as="p"
                class="eyebrow !border-white/30 !bg-white/12 !text-white/84"
              />
            ) : (
              <p class="eyebrow !border-white/30 !bg-white/12 !text-white/84">{heroEyebrow}</p>
            )
          )}

          {isCmsTextValue(heroTitle) ? (
            <EditableText
              {...heroTitle}
              as="h1"
              class="mt-4 text-balance text-5xl leading-[1.05] text-white sm:text-6xl lg:text-7xl"
            />
          ) : (
            <h1 class="mt-4 text-balance text-5xl leading-[1.05] text-white sm:text-6xl lg:text-7xl">
              {heroTitle}
            </h1>
          )}

          {isCmsTextValue(heroSubtitle) ? (
            <EditableText
              {...heroSubtitle}
              as="p"
              class="mt-5 max-w-2xl text-base leading-relaxed text-white/82 sm:text-lg"
            />
          ) : (
            <p class="mt-5 max-w-2xl text-base leading-relaxed text-white/82 sm:text-lg">
              {heroSubtitle}
            </p>
          )}

          {(heroPrimaryCta || heroSecondaryCta) && (
            <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
              {heroPrimaryCta && (
                isCmsLinkValue(heroPrimaryCta) ? (
                  <EditableLink
                    {...heroPrimaryCta}
                    class="inline-flex items-center justify-center rounded-full bg-golden-sand px-7 py-3 text-sm font-semibold uppercase tracking-[0.06em] text-charcoal transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_14px_30px_rgba(247,180,94,0.35)]"
                  />
                ) : (
                  <a
                    href={heroPrimaryCta.href}
                    class="inline-flex items-center justify-center rounded-full bg-golden-sand px-7 py-3 text-sm font-semibold uppercase tracking-[0.06em] text-charcoal transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_14px_30px_rgba(247,180,94,0.35)]"
                  >
                    {heroPrimaryCta.label}
                  </a>
                )
              )}
              {heroSecondaryCta && (
                isCmsLinkValue(heroSecondaryCta) ? (
                  <EditableLink
                    {...heroSecondaryCta}
                    class="inline-flex items-center justify-center rounded-full border border-white/35 bg-white/10 px-7 py-3 text-sm font-semibold uppercase tracking-[0.06em] text-white backdrop-blur transition-colors hover:bg-white/20"
                  />
                ) : (
                  <a
                    href={heroSecondaryCta.href}
                    class="inline-flex items-center justify-center rounded-full border border-white/35 bg-white/10 px-7 py-3 text-sm font-semibold uppercase tracking-[0.06em] text-white backdrop-blur transition-colors hover:bg-white/20"
                  >
                    {heroSecondaryCta.label}
                  </a>
                )
              )}
            </div>
          )}
        </div>
      </div>
    </section>

    <slot />
  </div>
</BaseLayout>
