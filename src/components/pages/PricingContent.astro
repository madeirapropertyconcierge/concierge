---
import EditableLink from '../cms/EditableLink.astro';
import VisualPageLayout from './VisualPageLayout.astro';
import WhatsAppButton from '../WhatsAppButton.astro';
import EditableText from '../cms/EditableText.astro';
import SharedPackageText from '../cms/SharedPackageText.astro';
import PricingTierCard from '../pricing/PricingTierCard.astro';
import { routeMap } from '../../i18n/routes';
import type { Locale } from '../../i18n/utils';
import { breadcrumbJsonLd } from '../../lib/seo';
import { madeiraImages } from '../../lib/madeiraImages';
import { getPricingPageContent } from '../../lib/pageContent/pricing';
import { getSiteChromeContent } from '../../lib/pageContent/siteChrome';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const routes = routeMap[lang];
const [copy, siteChrome] = await Promise.all([
  getPricingPageContent(lang),
  getSiteChromeContent(lang),
]);

const pageSchema = [
  breadcrumbJsonLd([
    { name: siteChrome.nav.home, url: routes.home },
    { name: siteChrome.nav.pricing, url: routes.pricing },
  ]),
  {
    '@context': 'https://schema.org',
    '@type': 'OfferCatalog',
    name: `${siteChrome.nav.pricing} | ${siteChrome.brand.fullName}`,
    itemListElement: copy.tiers.map((tier, index) => ({
      '@type': 'Offer',
      position: index + 1,
      name: tier.title,
    })),
  },
];
---

<VisualPageLayout
  lang={lang}
  title=""
  description=""
  heroEyebrow={copy.heroEyebrow}
  heroTitle={copy.heroTitle}
  heroSubtitle={copy.heroSubtitle}
  heroImage={madeiraImages.treeFramedValleyTown.src}
  heroAlt={madeiraImages.treeFramedValleyTown.alt}
  heroPrimaryCta={copy.heroPrimaryCta}
  heroSecondaryCta={copy.heroSecondaryCta}
  jsonLd={pageSchema}
>
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
    <div class="pricing-grid grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      {copy.tiers.map((tier, index) => (
        <PricingTierCard
          tier={tier}
          index={index}
          customQuoteLabel={copy.customQuote}
          primaryCta={copy.ctaPrimary}
          projectCta={copy.tierProjectCta}
          includesLabel={copy.includesLabel}
          idealForLabel={copy.idealForLabel}
        />
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-4 pb-20 sm:px-6 lg:px-8 lg:pb-24">
    <div class="premium-panel p-6 sm:p-8">
      <SharedPackageText
        packageKey={copy.addOnsTier.key}
        field="tierLabel"
        value={copy.addOnsTier.tierLabel}
        kind="inline"
        as="p"
        class="eyebrow"
      />
      <SharedPackageText
        packageKey={copy.addOnsTier.key}
        field="title"
        value={copy.addOnsTier.title}
        kind="inline"
        as="h2"
        class="mt-2 text-3xl text-charcoal"
      />
      <SharedPackageText
        packageKey={copy.addOnsTier.key}
        field="audience"
        value={copy.addOnsTier.audience}
        kind="inline"
        as="p"
        class="mt-2 text-sm leading-relaxed text-charcoal/66"
      />
      <div class="mt-5 grid gap-3 sm:grid-cols-3">
        {copy.addOnsTier.features.map((feature, featureIndex) => (
          <article class="step-card pricing-shared-card flex items-center gap-3">
            <span aria-hidden="true" class="h-2 w-2 flex-shrink-0 rounded-full bg-ocean-blue"></span>
            <SharedPackageText
              packageKey={copy.addOnsTier.key}
              field="feature"
              index={featureIndex}
              value={feature}
              kind="inline"
              as="p"
              class="text-sm leading-relaxed text-charcoal/75"
            />
          </article>
        ))}
      </div>
      <EditableLink
        {...copy.tierProjectCta}
        class="mt-6 inline-flex items-center justify-center rounded-full bg-charcoal px-6 py-3 text-xs font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-ocean-blue"
      />
    </div>
  </section>

  <section class="relative isolate overflow-hidden px-4 pb-20 sm:px-6 lg:px-8 lg:pb-24">
    <img
      src={madeiraImages.machicoFireFestival.src}
      alt={madeiraImages.machicoFireFestival.alt}
      class="absolute inset-0 -z-20 h-full w-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 -z-10 bg-[linear-gradient(100deg,rgba(11,24,30,0.87)_0%,rgba(11,24,30,0.67)_55%,rgba(11,24,30,0.83)_100%)]"></div>

    <div class="mx-auto max-w-4xl px-4 py-14 text-center text-white sm:px-6 lg:py-20">
      <EditableText
        {...copy.ctaTitle}
        as="h2"
        class="text-balance text-4xl leading-[1.05] text-white sm:text-5xl"
      />
      <EditableText
        {...copy.ctaBody}
        as="p"
        class="mx-auto mt-5 max-w-2xl text-base leading-relaxed text-white/80 sm:text-lg"
      />
      <EditableLink
        {...copy.ctaPrimary}
        class="mt-8 inline-flex items-center justify-center rounded-full bg-white px-8 py-3 text-sm font-semibold uppercase tracking-[0.06em] text-charcoal transition-colors hover:bg-golden-sand"
      />
    </div>
  </section>
</VisualPageLayout>

<WhatsAppButton lang={lang} />

<style>
  .pricing-grid {
    grid-template-rows: auto;
  }

  @supports (grid-template-rows: subgrid) {
    .pricing-grid {
      grid-template-rows: repeat(4, auto);
    }

    .pricing-grid > :global(.pricing-card) {
      grid-row: span 4;
      grid-template-rows: subgrid;
    }
  }

  .pricing-card {
    transition: transform 240ms ease, box-shadow 240ms ease, border-color 240ms ease;
  }

  .pricing-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 30px 62px rgba(16, 32, 43, 0.17);
  }

  .pricing-quote {
    line-height: 1.2;
  }

  .pricing-shared-card {
    min-height: 6.25rem;
  }

  @media (max-width: 767px) {
    .pricing-card,
    .pricing-shared-card {
      min-height: 0;
    }

    .pricing-card:hover {
      transform: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pricing-card {
      transition: none;
    }

    .pricing-card:hover {
      transform: none;
    }
  }
</style>
