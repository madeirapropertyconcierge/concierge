---
import VisualPageLayout from './VisualPageLayout.astro';
import WhatsAppButton from '../WhatsAppButton.astro';
import PricingTierCard from '../pricing/PricingTierCard.astro';
import { t } from '../../i18n/utils';
import { routeMap } from '../../i18n/routes';
import type { Locale } from '../../i18n/utils';
import { breadcrumbJsonLd } from '../../lib/seo';
import { madeiraImages } from '../../lib/madeiraImages';
import { getPricingPageContent } from '../../lib/pageContent/pricing';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const routes = routeMap[lang];
const copy = getPricingPageContent(lang);

const pageSchema = [
  breadcrumbJsonLd([
    { name: 'Home', url: routes.home },
    { name: t(lang, 'nav.pricing'), url: routes.pricing },
  ]),
  {
    '@context': 'https://schema.org',
    '@type': 'OfferCatalog',
    name: `${t(lang, 'nav.pricing')} | Madeira Property Concierge`,
    itemListElement: copy.tiers.map((tier, index) => ({
      '@type': 'Offer',
      position: index + 1,
      name: tier.title,
    })),
  },
];
---

<VisualPageLayout
  lang={lang}
  title={t(lang, 'pricing.metaTitle')}
  description={t(lang, 'pricing.metaDescription')}
  heroEyebrow={copy.heroEyebrow}
  heroTitle={copy.heroTitle}
  heroSubtitle={copy.heroSubtitle}
  heroImage={madeiraImages.treeFramedValleyTown.src}
  heroAlt={madeiraImages.treeFramedValleyTown.alt}
  heroPrimaryCta={{ label: copy.ctaPrimary, href: routes.contact }}
  heroSecondaryCta={{ label: t(lang, 'nav.services'), href: routes.services }}
  jsonLd={pageSchema}
>
  <section data-cms-ignore="all" class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
    <div class="pricing-grid grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      {copy.tiers.map((tier, index) => (
        <PricingTierCard
          tier={tier}
          index={index}
          customQuoteLabel={copy.customQuote}
          primaryCtaLabel={copy.ctaPrimary}
          projectCtaLabel={copy.ctaProject}
          contactHref={routes.contact}
          includesLabel={copy.includesLabel}
          idealForLabel={copy.idealForLabel}
        />
      ))}
    </div>
  </section>

  <section data-cms-ignore="all" class="mx-auto max-w-5xl px-4 pb-20 sm:px-6 lg:px-8 lg:pb-24">
    <div class="premium-panel p-6 sm:p-8">
      <p class="eyebrow">{copy.transparencyTitle}</p>
      <div class="mt-5 grid gap-3 sm:grid-cols-3">
        {copy.transparencyItems.map((item) => (
          <article class="step-card pricing-shared-card flex items-center gap-3">
            <span aria-hidden="true" class="h-2 w-2 flex-shrink-0 rounded-full bg-ocean-blue"></span>
            <p class="text-sm leading-relaxed text-charcoal/75">{item}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section data-cms-ignore="all" class="relative isolate overflow-hidden px-4 pb-20 sm:px-6 lg:px-8 lg:pb-24">
    <img
      src={madeiraImages.machicoFireFestival.src}
      alt={madeiraImages.machicoFireFestival.alt}
      class="absolute inset-0 -z-20 h-full w-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 -z-10 bg-[linear-gradient(100deg,rgba(11,24,30,0.87)_0%,rgba(11,24,30,0.67)_55%,rgba(11,24,30,0.83)_100%)]"></div>

    <div class="mx-auto max-w-4xl px-4 py-14 text-center text-white sm:px-6 lg:py-20">
      <h2 class="text-balance text-4xl leading-[1.05] text-white sm:text-5xl">{copy.ctaTitle}</h2>
      <p class="mx-auto mt-5 max-w-2xl text-base leading-relaxed text-white/80 sm:text-lg">{copy.ctaBody}</p>
      <a href={routes.contact} class="mt-8 inline-flex items-center justify-center rounded-full bg-white px-8 py-3 text-sm font-semibold uppercase tracking-[0.06em] text-charcoal transition-colors hover:bg-golden-sand">{copy.ctaPrimary}</a>
    </div>
  </section>
</VisualPageLayout>

<WhatsAppButton lang={lang} />

<style>
  .pricing-grid {
    grid-auto-rows: 1fr;
  }

  .pricing-card {
    min-height: 33.5rem;
    transition: transform 240ms ease, box-shadow 240ms ease, border-color 240ms ease;
  }

  .pricing-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 30px 62px rgba(16, 32, 43, 0.17);
  }

  .pricing-quote {
    line-height: 1.2;
  }

  .pricing-shared-card {
    min-height: 6.25rem;
  }

  @media (max-width: 767px) {
    .pricing-card,
    .pricing-shared-card {
      min-height: 0;
    }

    .pricing-card:hover {
      transform: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pricing-card {
      transition: none;
    }

    .pricing-card:hover {
      transform: none;
    }
  }
</style>
