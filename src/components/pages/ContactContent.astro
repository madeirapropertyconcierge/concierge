---
import EditableImage from '../cms/EditableImage.astro';
import EditableLink from '../cms/EditableLink.astro';
import EditableText from '../cms/EditableText.astro';
import VisualPageLayout from './VisualPageLayout.astro';
import ContactForm from '../ContactForm.astro';
import WhatsAppButton from '../WhatsAppButton.astro';
import { routeMap } from '../../i18n/routes';
import { SITE, FORMSPREE_ENDPOINT } from '../../lib/constants';
import type { Locale } from '../../i18n/utils';
import { breadcrumbJsonLd, absoluteUrl } from '../../lib/seo';
import { madeiraImages } from '../../lib/madeiraImages';
import { loadRequiredPageFields } from '../../lib/pageContent/cmsPageText';
import { loadContactServiceOptions } from '../../lib/pageContent/packages';
import { getSiteChromeContent } from '../../lib/pageContent/siteChrome';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const routes = routeMap[lang];
const pageId = lang === 'en' ? 'en-contact' : 'pt-contacto';
const [contactServiceLabels, pageFields, siteChrome] = await Promise.all([
  loadContactServiceOptions(lang),
  loadRequiredPageFields(pageId, lang, {
    texts: [
      'text:hero-eyebrow',
      'text:hero-title',
      'text:hero-subtitle',
      'text:form-name',
      'text:form-email',
      'text:form-phone',
      'text:form-property-type',
      'text:form-property-type-apartment',
      'text:form-property-type-villa',
      'text:form-property-type-commercial',
      'text:form-property-type-land',
      'text:form-property-type-other',
      'text:form-service',
      'text:form-service-not-sure',
      'text:form-message',
      'text:form-submit',
      'text:form-sending',
      'text:form-success',
      'text:form-error',
      'text:form-select-placeholder',
      'text:side-title',
      'text:side-body',
      'text:hours',
      'text:form-notice-prefix',
      'text:form-notice-suffix',
      'text:contact-email-badge',
      'text:contact-phone-badge',
      'text:contact-whatsapp-badge',
      'text:contact-whatsapp-label',
      'text:contact-location-badge',
    ] as const,
    links: [
      'link:primary-cta',
      'link:secondary-cta',
      'link:privacy-policy',
    ] as const,
    images: [
      'image:side-photo',
    ] as const,
  }),
  getSiteChromeContent(lang),
]);

const formLabels = {
  name: pageFields.texts['text:form-name'].value,
  email: pageFields.texts['text:form-email'].value,
  phone: pageFields.texts['text:form-phone'].value,
  propertyType: pageFields.texts['text:form-property-type'].value,
  propertyTypes: {
    apartment: pageFields.texts['text:form-property-type-apartment'].value,
    villa: pageFields.texts['text:form-property-type-villa'].value,
    commercial: pageFields.texts['text:form-property-type-commercial'].value,
    land: pageFields.texts['text:form-property-type-land'].value,
    other: pageFields.texts['text:form-property-type-other'].value,
  },
  service: pageFields.texts['text:form-service'].value,
  serviceOptions: {
    essentialCare: contactServiceLabels.essentialCare,
    managedCare: contactServiceLabels.managedCare,
    premiumCare: contactServiceLabels.premiumCare,
    revenueHosting: contactServiceLabels.revenueHosting,
    onDemand: contactServiceLabels.onDemand,
    addOns: contactServiceLabels.addOns,
    notSure: pageFields.texts['text:form-service-not-sure'].value,
  },
  selectPlaceholder: pageFields.texts['text:form-select-placeholder'].value,
  message: pageFields.texts['text:form-message'].value,
  submit: pageFields.texts['text:form-submit'].value,
  sending: pageFields.texts['text:form-sending'].value,
  success: pageFields.texts['text:form-success'].value,
  error: pageFields.texts['text:form-error'].value,
};

const pageSchema = [
  breadcrumbJsonLd([
    { name: siteChrome.nav.home, url: routes.home },
    { name: siteChrome.nav.contact, url: routes.contact },
  ]),
  {
    '@context': 'https://schema.org',
    '@type': 'ContactPage',
    name: siteChrome.nav.contact,
    url: absoluteUrl(routes.contact),
  },
];
---

<VisualPageLayout
  lang={lang}
  title=""
  description=""
  heroEyebrow={pageFields.texts['text:hero-eyebrow']}
  heroTitle={pageFields.texts['text:hero-title']}
  heroSubtitle={pageFields.texts['text:hero-subtitle']}
  heroImage={madeiraImages.oceanfrontBench.src}
  heroAlt={madeiraImages.oceanfrontBench.alt}
  heroPrimaryCta={pageFields.links['link:primary-cta']}
  heroSecondaryCta={pageFields.links['link:secondary-cta']}
  jsonLd={pageSchema}
>
  <section id="contact-form" class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
    <div class="grid gap-8 lg:grid-cols-[1.06fr_0.94fr]">
      <div class="premium-panel p-6 sm:p-8 lg:p-10">
        <ContactForm lang={lang} formspreeEndpoint={FORMSPREE_ENDPOINT} labels={formLabels} />
        <p class="mt-4 text-xs leading-relaxed text-charcoal/62">
          <EditableText {...pageFields.texts['text:form-notice-prefix']} as="span" />
          {' '}
          <EditableLink
            {...pageFields.links['link:privacy-policy']}
            class="font-semibold text-ocean-blue transition-colors hover:text-charcoal"
          />
          <EditableText {...pageFields.texts['text:form-notice-suffix']} as="span" />
        </p>
      </div>

      <div class="space-y-5">
        <article class="media-card reveal min-h-[15rem]">
          <EditableImage
            {...pageFields.images['image:side-photo']}
            class="h-full w-full object-cover"
            loading="lazy"
          />
        </article>

        <article class="premium-panel p-6 sm:p-7">
          <EditableText {...pageFields.texts['text:side-title']} as="p" class="eyebrow" />
          <EditableText
            {...pageFields.texts['text:side-body']}
            as="p"
            class="mt-3 text-sm leading-relaxed text-charcoal/72 sm:text-base"
          />

          <div class="mt-6 space-y-3 text-sm text-charcoal/80 sm:text-base">
            <a href={`mailto:${SITE.email}`} class="flex items-center gap-2 transition-colors hover:text-ocean-blue">
              <EditableText {...pageFields.texts['text:contact-email-badge']} as="span" class="step-index !px-2 !py-1" />
              <span>{SITE.email}</span>
            </a>
            <a href={`tel:${SITE.phone.replace(/\s/g, '')}`} class="flex items-center gap-2 transition-colors hover:text-ocean-blue">
              <EditableText {...pageFields.texts['text:contact-phone-badge']} as="span" class="step-index !px-2 !py-1" />
              <span>{SITE.phone}</span>
            </a>
            <a href={`https://wa.me/${SITE.whatsapp}`} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 transition-colors hover:text-ocean-blue">
              <EditableText {...pageFields.texts['text:contact-whatsapp-badge']} as="span" class="step-index !px-2 !py-1" />
              <EditableText {...pageFields.texts['text:contact-whatsapp-label']} as="span" />
            </a>
            <p class="flex items-center gap-2">
              <EditableText {...pageFields.texts['text:contact-location-badge']} as="span" class="step-index !px-2 !py-1" />
              <span>{SITE.address}</span>
            </p>
          </div>

          <EditableText
            {...pageFields.texts['text:hours']}
            as="p"
            class="mt-5 text-xs uppercase tracking-[0.14em] text-charcoal/50"
          />
        </article>
      </div>
    </div>
  </section>
</VisualPageLayout>

<WhatsAppButton lang={lang} />
