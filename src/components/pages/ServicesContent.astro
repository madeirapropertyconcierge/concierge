---
import VisualPageLayout from './VisualPageLayout.astro';
import WhatsAppButton from '../WhatsAppButton.astro';
import { t } from '../../i18n/utils';
import { routeMap } from '../../i18n/routes';
import type { Locale } from '../../i18n/utils';
import { breadcrumbJsonLd, serviceListJsonLd } from '../../lib/seo';
import { madeiraImages } from '../../lib/madeiraImages';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const routes = routeMap[lang];

const copy =
  lang === 'pt'
    ? {
        heroEyebrow: 'Níveis de Serviço',
        heroTitle: 'Quatro níveis claros para proprietários no estrangeiro.',
        heroSubtitle:
          'Dos cuidados essenciais ao apoio concierge sob pedido, escolhe a profundidade de apoio e nós executamos na ilha.',
        introEyebrow: 'Níveis de Serviço',
        introTitle: 'Estrutura clara que cresce com o seu imóvel.',
        introBody:
          'Cada nível foi pensado para proteger o seu ativo, simplificar a coordenação local e dar-lhe tranquilidade enquanto gere à distância.',
        tiers: [
          {
            title: 'Tier A - Pacote de Cuidados Essenciais',
            price: '€95/mês',
            image: '/images/library/img-0919.jpg',
            audience:
              'Pensado para proprietários no estrangeiro que querem tranquilidade, sabendo que a sua propriedade está a ser verificada e mantida na sua ausência.',
            bullets: [
              'Inspeção mensal ao interior e exterior da propriedade',
              'Ventilação e circulação de água para prevenir problemas',
              'Verificação visual de fugas, humidade, pragas ou danos causados pelo tempo',
            ],
          },
          {
            title: 'Tier B - Pacote de Cuidados Standard',
            price: '€180/mês',
            image: madeiraImages.coastalVillageAerial.src,
            audience:
              'A nossa opção mais popular, oferecendo monitorização reforçada e coordenação local para proprietários que vivem no estrangeiro.',
            bullets: [
              'Tudo incluído no pacote Essencial, mais inspeções à propriedade duas vezes por mês',
              'Guarda segura de chaves e coordenação com profissionais e prestadores de serviços locais de confiança',
              'Apoio ao acesso de hóspedes e resposta prioritária para situações urgentes',
            ],
          },
          {
            title: 'Tier C - Pacote Concierge Premium',
            price: '€295/mês',
            image: madeiraImages.santanaCottageGarden.src,
            audience:
              'Um serviço totalmente gerido para proprietários internacionais que procuram total tranquilidade.',
            bullets: [
              'Tudo incluído no pacote Standard, mais verificações da propriedade sob pedido',
              'Preparação da casa antes da sua chegada e inspeções após a sua partida da ilha',
              'Gestão de utilidades, apoio com serviços locais e relatórios fotográficos detalhados',
            ],
          },
          {
            title: 'Serviços Concierge Personalizados',
            price: 'Desde €35/hora',
            image: madeiraImages.santanaHouseFacade.src,
            audience:
              'Apoio flexível e sob pedido para situações que exigem uma pessoa de confiança no terreno.',
            bullets: [
              'Chamadas de emergência, espera por reparações, inspeções ou entregas',
              'Coordenação de limpezas, inventário, verificações de estado e apoio administrativo local',
              'Assistência em renovações ou setup, com retentores mensais disponíveis para apoio contínuo',
            ],
          },
        ],
        addOnsTitle: 'Add-ons opcionais',
        addOnsSubtitle: 'Serviços extra ativados conforme necessário para apoio pontual no terreno.',
        addOnLabel: 'Add-on',
        addOns: [
          { title: 'Visitas adicionais à propriedade', price: '€30 por visita' },
          { title: 'Inspeção de tempestade (fora do pacote)', price: '€40' },
          { title: 'Preparação de boas-vindas para hóspedes (limpeza e essenciais)', price: 'Desde €75' },
          { title: 'Relatório anual ou inspeção pré-compra', price: 'Desde €150' },
          { title: 'Coordenação de entrega de chaves', price: '€25' },
          { title: 'Styling interior e fotografia profissional', price: 'Orçamento por escopo' },
          { title: 'Coordenação de renovação e fornecedores', price: 'Orçamento por escopo' },
        ],
        ctaTitle: 'Sugerimos o nível que encaixa na sua situação, não o mais caro.',
        ctaBody: 'Na primeira chamada, olhamos para os seus objetivos, o imóvel e o que precisa de ser feito. Depois recomendamos um nível.',
        ctaPrimary: 'Marcar Chamada de Diagnóstico',
        ctaSecondary: 'Ver Preços',
      }
    : {
        heroEyebrow: 'Service Tiers',
        heroTitle: 'Four clear service levels for overseas owners.',
        heroSubtitle:
          'From essential care to on-demand concierge support, choose the service depth you need and we execute on-island.',
        introEyebrow: 'Service Tiers',
        introTitle: 'A clear structure that grows with your property.',
        introBody:
          'Each tier is designed to protect your asset, simplify local coordination, and give you peace of mind while you manage from abroad.',
        tiers: [
          {
            title: 'Tier A - Essential Care Package',
            price: '€95/month',
            image: '/images/library/img-0919.jpg',
            audience:
              'Designed for overseas owners who want peace of mind knowing their property is being checked and maintained in their absence.',
            bullets: [
              'Monthly interior and exterior property inspection',
              'Ventilation and water run-through to prevent issues',
              'Visual checks for leaks, damp, pests, or weather damage',
            ],
          },
          {
            title: 'Tier B - Standard Care Package',
            price: '€180/month',
            image: madeiraImages.coastalVillageAerial.src,
            audience:
              'Our most popular option, offering enhanced monitoring and local coordination for owners living abroad.',
            bullets: [
              'Includes everything in the Essential package, plus bi-monthly property inspections',
              'Secure key holding and coordination with trusted local trades and service providers',
              'Guest access support and priority response for urgent situations',
            ],
          },
          {
            title: 'Tier C - Premium Concierge Package',
            price: '€295/month',
            image: madeiraImages.santanaCottageGarden.src,
            audience:
              'A fully managed service for international owners seeking complete peace of mind.',
            bullets: [
              'Includes everything in the Standard package, plus on-demand property checks',
              'Pre-arrival home prep before your visit and post-departure inspections after you leave the island',
              'Utility management, local service coordination, and detailed photo reporting',
            ],
          },
          {
            title: 'Bespoke Concierge Services',
            price: 'From €35/hour',
            image: madeiraImages.santanaHouseFacade.src,
            audience:
              'Flexible, on-demand support for situations that require a trusted person on the ground.',
            bullets: [
              'Emergency call-outs, waiting for repairs, inspections, or deliveries',
              'Cleaning coordination, inventory and condition checks, and local administrative support',
              'Renovation or setup assistance, with custom monthly retainers available for ongoing support',
            ],
          },
        ],
        addOnsTitle: 'Optional add-ons',
        addOnsSubtitle: 'Additional services activated as needed for extra on-the-ground support.',
        addOnLabel: 'Add-on',
        addOns: [
          { title: 'Additional property visits', price: '€30 per visit' },
          { title: 'Storm inspection (outside package)', price: '€40' },
          { title: 'Guest welcome preparation (cleaning & essentials)', price: 'From €75' },
          { title: 'Annual or pre-purchase inspection report', price: 'From €150' },
          { title: 'Key handover coordination', price: '€25' },
          { title: 'Interior styling and professional listing photography', price: 'Scoped quote' },
          { title: 'Renovation/vendor project coordination', price: 'Scoped quote' },
        ],
        ctaTitle: 'We\'ll suggest the tier that fits your situation, not the most expensive one.',
        ctaBody: 'In the first call, we look at your goals, your property, and what actually needs doing. Then we recommend a tier.',
        ctaPrimary: 'Book Diagnostic Call',
        ctaSecondary: 'View Pricing',
      };

const pageSchema = [
  breadcrumbJsonLd([
    { name: 'Home', url: routes.home },
    { name: t(lang, 'nav.services'), url: routes.services },
  ]),
  serviceListJsonLd(
    `${t(lang, 'nav.services')} | Madeira Property Concierge`,
    t(lang, 'services.metaDescription'),
    routes.services,
    copy.tiers.map((tier) => tier.title),
  ),
];
---

<VisualPageLayout
  lang={lang}
  title={t(lang, 'services.metaTitle')}
  description={t(lang, 'services.metaDescription')}
  heroEyebrow={copy.heroEyebrow}
  heroTitle={copy.heroTitle}
  heroSubtitle={copy.heroSubtitle}
  heroImage={madeiraImages.mercadoMural.src}
  heroAlt={madeiraImages.mercadoMural.alt}
  heroPrimaryCta={{ label: copy.ctaPrimary, href: routes.contact }}
  heroSecondaryCta={{ label: copy.ctaSecondary, href: routes.pricing }}
  jsonLd={pageSchema}
>
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
    <div class="mb-10 grid gap-6 lg:grid-cols-[1fr_auto] lg:items-end">
      <div class="max-w-3xl">
        <p class="eyebrow">{copy.introEyebrow}</p>
        <h2 class="mt-3 text-4xl leading-[1.05] text-charcoal sm:text-5xl">{copy.introTitle}</h2>
        <p class="mt-4 max-w-2xl text-sm leading-relaxed text-charcoal/72 sm:text-base">{copy.introBody}</p>
      </div>
    </div>

    <div class="grid gap-6 md:grid-cols-2">
      {copy.tiers.map((tier, index) => (
        <article class:list={['service-tile reveal aspect-[16/10]', index > 0 ? 'reveal-delay-1' : '']}>
          <img src={tier.image} alt={tier.title} class="h-full w-full object-cover" loading="lazy" />
          <div class="service-overlay">
            <p class="eyebrow w-fit !border-white/30 !bg-white/10 !text-white/84">{tier.price}</p>
            <h3 class="text-3xl text-white">{tier.title}</h3>
            <p class="text-sm text-white/82">{tier.audience}</p>
            <ul class="space-y-1 text-sm text-white/84">
              {tier.bullets.map((bullet) => (
                <li class="flex items-start gap-2">
                  <span class="mt-1 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-golden-sand"></span>
                  <span>{bullet}</span>
                </li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8 lg:pb-24">
    <div class="premium-panel p-6 sm:p-8 lg:p-10">
      <div class="mb-6">
        <p class="eyebrow">{copy.addOnsTitle}</p>
        <p class="mt-3 max-w-2xl text-sm leading-relaxed text-charcoal/72 sm:text-base">{copy.addOnsSubtitle}</p>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {copy.addOns.map((item) => (
          <div class="step-card">
            <p class="text-xs uppercase tracking-[0.12em] text-charcoal/55">{copy.addOnLabel}</p>
            <h3 class="mt-2 text-xl text-charcoal">{item.title}</h3>
            <p class="mt-2 text-sm font-semibold text-ocean-blue">{item.price}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="relative isolate overflow-hidden px-4 pb-20 sm:px-6 lg:px-8 lg:pb-24">
    <img
      src={madeiraImages.cliffsPeninsula.src}
      alt={madeiraImages.cliffsPeninsula.alt}
      class="absolute inset-0 -z-20 h-full w-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 -z-10 bg-[linear-gradient(100deg,rgba(11,24,30,0.87)_0%,rgba(11,24,30,0.67)_55%,rgba(11,24,30,0.83)_100%)]"></div>

    <div class="mx-auto max-w-4xl px-4 py-14 text-center text-white sm:px-6 lg:py-20">
      <h2 class="text-balance text-4xl leading-[1.05] text-white sm:text-5xl">{copy.ctaTitle}</h2>
      <p class="mx-auto mt-5 max-w-2xl text-base leading-relaxed text-white/80 sm:text-lg">{copy.ctaBody}</p>

      <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
        <a href={routes.contact} class="inline-flex items-center justify-center rounded-full bg-white px-8 py-3 text-sm font-semibold uppercase tracking-[0.06em] text-charcoal transition-colors hover:bg-golden-sand">{copy.ctaPrimary}</a>
        <a href={routes.pricing} class="inline-flex items-center justify-center rounded-full border border-white/35 bg-white/8 px-8 py-3 text-sm font-semibold uppercase tracking-[0.06em] text-white backdrop-blur transition-colors hover:bg-white/20">{copy.ctaSecondary}</a>
      </div>
    </div>
  </section>
</VisualPageLayout>

<WhatsAppButton lang={lang} />
