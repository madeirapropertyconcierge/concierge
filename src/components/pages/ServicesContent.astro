---
import VisualPageLayout from './VisualPageLayout.astro';
import WhatsAppButton from '../WhatsAppButton.astro';
import { t } from '../../i18n/utils';
import { routeMap } from '../../i18n/routes';
import type { Locale } from '../../i18n/utils';
import { breadcrumbJsonLd, serviceListJsonLd } from '../../lib/seo';
import { pexelsMadeiraImages } from '../../lib/pexelsImages';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const routes = routeMap[lang];

const copy =
  lang === 'pt'
    ? {
        heroEyebrow: 'Níveis de Serviço',
        heroTitle: 'Quatro níveis claros para proprietários no estrangeiro.',
        heroSubtitle:
          'Da guarda de chaves à gestão AL full-service, escolhe a profundidade de apoio e nós executamos na ilha.',
        introEyebrow: 'Níveis de Serviço',
        introTitle: 'Estrutura objetiva, com upgrade progressivo conforme a fase do imóvel.',
        introBody:
          'Os planos foram desenhados para proteger o ativo, manter operação consistente e dar tranquilidade a quem não está fisicamente na Madeira.',
        tiers: [
          {
            title: 'Tier A - Guarda de Chaves + Home Care',
            price: '€100-€250/mês',
            image: pexelsMadeiraImages.hillsideHomes.src,
            audience: 'Para segunda habitação e imóveis com ocupação parcial.',
            bullets: ['Visitas programadas com fotos, verificação de humidade, fugas e ventilação', 'Preparação e inspeção pós-tempestade, correio e ligação com vizinhança', 'Coordenação de manutenção preventiva antes de problemas escalarem'],
          },
          {
            title: 'Tier B - Hosting Essentials',
            price: '15%-18% da receita bruta de alojamento',
            image: pexelsMadeiraImages.coastalVillageAerial.src,
            audience: 'Para proprietários que fazem as reservas, mas precisam de operação local fiável.',
            bullets: ['Mensagens e triagem de hóspedes, check-in/check-out e gestão de acessos', 'Coordenação de limpezas, lavandaria e reposição de consumíveis', 'Gestão de incidentes durante estadias e resposta a avaliações'],
          },
          {
            title: 'Tier C - Gestão Full-Service',
            price: '20%-25% da receita bruta de alojamento',
            image: pexelsMadeiraImages.santanaCottageGarden.src,
            audience: 'Para quem quer delegar a operação de ponta a ponta.',
            bullets: ['Gestão de anúncios, calendário e pricing dinâmico (Airbnb/Booking/VRBO)', 'Coordenação de manutenção com controlo de fornecedores e fotos antes/depois', 'Apoio AL, SIBA/RNAL e relatório mensal ao proprietário com receitas e despesas'],
          },
          {
            title: 'Tier D - Premium / White-Glove (Fase 2)',
            price: '€50-€150 por estadia',
            image: pexelsMadeiraImages.santanaHouseFacade.src,
            audience: 'Camada de hospitalidade premium para elevar experiência e avaliações.',
            bullets: ['Welcome packs curados, pré-stock de mercearia e personalização de estadias', 'Reservas e experiências locais, incluindo serviços family-friendly validados', 'SLA acelerado: resposta de emergência em 15 minutos'],
          },
        ],
        addOnsTitle: 'Serviços por projeto (add-ons)',
        addOnsSubtitle: 'Ativamos quando necessário para setup, valorização e eficiência operacional.',
        addOnLabel: 'Projeto',
        addOns: [
          { title: 'Styling interior + fotografia profissional', price: '€300-€800' },
          { title: 'Coordenação de renovação e fornecedores', price: 'Orçamento por escopo' },
          { title: 'Manual de casa otimizado (UX, digital/físico)', price: 'Orçamento por escopo' },
          { title: 'Setup smart lock, ruído e energia', price: 'Orçamento por escopo' },
        ],
        ctaTitle: 'Escolhemos o nível certo para o seu contexto, sem excesso de serviço.',
        ctaBody: 'Na chamada inicial avaliamos objetivos, risco operacional e estágio do imóvel para recomendar a estrutura certa.',
        ctaPrimary: 'Marcar Chamada de Diagnóstico',
        ctaSecondary: 'Ver Preços',
      }
    : {
        heroEyebrow: 'Service Tiers',
        heroTitle: 'Four clear service levels for overseas owners.',
        heroSubtitle:
          'From keyholding to full AL management, choose the service depth you need and we execute on-island.',
        introEyebrow: 'Service Tiers',
        introTitle: 'A clear structure with a natural upgrade path as your property evolves.',
        introBody:
          'Each tier is built to protect your asset, keep operations consistent, and remove stress for owners managing remotely.',
        tiers: [
          {
            title: 'Tier A - Keyholding + Home Care',
            price: '€100-€250/month',
            image: pexelsMadeiraImages.hillsideHomes.src,
            audience: 'For second homes and part-time rentals.',
            bullets: ['Scheduled visits with photos, plus humidity, leak, and ventilation checks', 'Storm prep and post-storm inspections, mail, and neighbour liaison', 'Preventative maintenance coordination before issues escalate'],
          },
          {
            title: 'Tier B - Hosting Essentials',
            price: '15%-18% of gross rental income',
            image: pexelsMadeiraImages.coastalVillageAerial.src,
            audience: 'For owners who handle bookings but need reliable local operations.',
            bullets: ['Guest messaging/screening, check-ins/check-outs, and access management', 'Cleaning, laundry, restocking, and pre-arrival verification', 'On-stay issue handling and guest review support'],
          },
          {
            title: 'Tier C - Full-Service Management',
            price: '20%-25% of gross rental income',
            image: pexelsMadeiraImages.santanaCottageGarden.src,
            audience: 'For owners who want end-to-end delegation.',
            bullets: ['Listing, calendar, and dynamic pricing management across channels', 'Maintenance coordination with vendor QA and before/after documentation', 'AL/SIBA/RNAL compliance support and monthly owner reporting'],
          },
          {
            title: 'Tier D - Premium / White-Glove (Phase 2)',
            price: '€50-€150 per stay',
            image: pexelsMadeiraImages.santanaHouseFacade.src,
            audience: 'Premium hospitality layer for higher guest expectations and better reviews.',
            bullets: ['Curated welcome packs, pre-stocking, and personalized stay setup', 'Restaurant/experience booking plus vetted family-friendly services', 'Faster SLA: 15-minute emergency response target'],
          },
        ],
        addOnsTitle: 'Project-based add-ons',
        addOnsSubtitle: 'Activated when useful for setup, value growth, and operational efficiency.',
        addOnLabel: 'Project',
        addOns: [
          { title: 'Interior styling + professional photography', price: '€300-€800' },
          { title: 'Renovation project and vendor coordination', price: 'Scoped quote' },
          { title: 'UX-optimized house manual (digital/printed)', price: 'Scoped quote' },
          { title: 'Smart lock, noise monitor, and energy setup', price: 'Scoped quote' },
        ],
        ctaTitle: 'We recommend the right service depth for your real ownership context.',
        ctaBody: 'In your first call, we map goals, operational risk, and lifecycle stage to match you with the right tier.',
        ctaPrimary: 'Book Diagnostic Call',
        ctaSecondary: 'View Pricing',
      };

const pageSchema = [
  breadcrumbJsonLd([
    { name: 'Home', url: routes.home },
    { name: t(lang, 'nav.services'), url: routes.services },
  ]),
  serviceListJsonLd(
    `${t(lang, 'nav.services')} | Madeira Property Concierge`,
    t(lang, 'services.metaDescription'),
    routes.services,
    copy.tiers.map((tier) => tier.title),
  ),
];
---

<VisualPageLayout
  lang={lang}
  title={t(lang, 'services.metaTitle')}
  description={t(lang, 'services.metaDescription')}
  heroEyebrow={copy.heroEyebrow}
  heroTitle={copy.heroTitle}
  heroSubtitle={copy.heroSubtitle}
  heroImage={pexelsMadeiraImages.mercadoMural.src}
  heroAlt={pexelsMadeiraImages.mercadoMural.alt}
  heroPrimaryCta={{ label: copy.ctaPrimary, href: routes.contact }}
  heroSecondaryCta={{ label: copy.ctaSecondary, href: routes.pricing }}
  jsonLd={pageSchema}
>
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
    <div class="mb-10 grid gap-6 lg:grid-cols-[1fr_auto] lg:items-end">
      <div class="max-w-3xl">
        <p class="eyebrow">{copy.introEyebrow}</p>
        <h2 class="mt-3 text-4xl leading-[1.05] text-charcoal sm:text-5xl">{copy.introTitle}</h2>
        <p class="mt-4 max-w-2xl text-sm leading-relaxed text-charcoal/72 sm:text-base">{copy.introBody}</p>
      </div>
    </div>

    <div class="grid gap-6 md:grid-cols-2">
      {copy.tiers.map((tier, index) => (
        <article class:list={['service-tile reveal aspect-[16/10]', index > 0 ? 'reveal-delay-1' : '']}>
          <img src={tier.image} alt={tier.title} class="h-full w-full object-cover" loading="lazy" />
          <div class="service-overlay">
            <p class="eyebrow w-fit !border-white/30 !bg-white/10 !text-white/84">{tier.price}</p>
            <h3 class="text-3xl text-white">{tier.title}</h3>
            <p class="text-sm text-white/82">{tier.audience}</p>
            <ul class="space-y-1 text-sm text-white/84">
              {tier.bullets.map((bullet) => (
                <li class="flex items-start gap-2">
                  <span class="mt-1 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-golden-sand"></span>
                  <span>{bullet}</span>
                </li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8 lg:pb-24">
    <div class="premium-panel p-6 sm:p-8 lg:p-10">
      <div class="mb-6">
        <p class="eyebrow">{copy.addOnsTitle}</p>
        <p class="mt-3 max-w-2xl text-sm leading-relaxed text-charcoal/72 sm:text-base">{copy.addOnsSubtitle}</p>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {copy.addOns.map((item) => (
          <div class="step-card">
            <p class="text-xs uppercase tracking-[0.12em] text-charcoal/55">{copy.addOnLabel}</p>
            <h3 class="mt-2 text-xl text-charcoal">{item.title}</h3>
            <p class="mt-2 text-sm font-semibold text-ocean-blue">{item.price}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="relative isolate overflow-hidden px-4 pb-20 sm:px-6 lg:px-8 lg:pb-24">
    <img
      src={pexelsMadeiraImages.cliffsPeninsula.src}
      alt={pexelsMadeiraImages.cliffsPeninsula.alt}
      class="absolute inset-0 -z-20 h-full w-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 -z-10 bg-[linear-gradient(100deg,rgba(11,24,30,0.87)_0%,rgba(11,24,30,0.67)_55%,rgba(11,24,30,0.83)_100%)]"></div>

    <div class="mx-auto max-w-4xl px-4 py-14 text-center text-white sm:px-6 lg:py-20">
      <h2 class="text-balance text-4xl leading-[1.05] text-white sm:text-5xl">{copy.ctaTitle}</h2>
      <p class="mx-auto mt-5 max-w-2xl text-base leading-relaxed text-white/80 sm:text-lg">{copy.ctaBody}</p>

      <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
        <a href={routes.contact} class="inline-flex items-center justify-center rounded-full bg-white px-8 py-3 text-sm font-semibold uppercase tracking-[0.06em] text-charcoal transition-colors hover:bg-golden-sand">{copy.ctaPrimary}</a>
        <a href={routes.pricing} class="inline-flex items-center justify-center rounded-full border border-white/35 bg-white/8 px-8 py-3 text-sm font-semibold uppercase tracking-[0.06em] text-white backdrop-blur transition-colors hover:bg-white/20">{copy.ctaSecondary}</a>
      </div>
    </div>
  </section>
</VisualPageLayout>

<WhatsAppButton lang={lang} />
