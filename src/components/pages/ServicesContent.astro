---
import VisualPageLayout from './VisualPageLayout.astro';
import WhatsAppButton from '../WhatsAppButton.astro';
import EditableText from '../cms/EditableText.astro';
import SharedPackageText from '../cms/SharedPackageText.astro';
import { t } from '../../i18n/utils';
import { routeMap } from '../../i18n/routes';
import type { Locale } from '../../i18n/utils';
import { breadcrumbJsonLd, serviceListJsonLd } from '../../lib/seo';
import { madeiraImages } from '../../lib/madeiraImages';
import { loadRequiredPageText } from '../../lib/pageContent/cmsPageText';
import {
  loadCoreServicePackages,
  loadServicePackages,
  type ServicePackageKey,
} from '../../lib/pageContent/packages';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const routes = routeMap[lang];
const pageId = lang === 'en' ? 'en-services' : 'pt-servicos';
const packages = await loadCoreServicePackages(lang);
const addOns = (await loadServicePackages(lang)).find((item) => item.key === 'addOns');
const addOnQuoteLabel = await loadRequiredPageText(pageId, 'text:add-on-quote-label', lang);

if (!addOns) {
  throw new Error('Optional add-ons package is missing.');
}

const tileImages: Record<Exclude<ServicePackageKey, 'addOns'>, string> = {
  essentialCare: '/images/library/img-0919.jpg',
  managedCare: madeiraImages.coastalVillageAerial.src,
  premiumCare: madeiraImages.santanaCottageGarden.src,
  revenueHosting: madeiraImages.mercadoMural.src,
  onDemand: madeiraImages.santanaHouseFacade.src,
};

const copy =
  lang === 'pt'
    ? {
        heroEyebrow: 'Pacotes de Servico',
        heroTitle: 'Cinco pacotes claros para proprietarios no estrangeiro.',
        heroSubtitle:
          'Desde o cuidado base do imovel ate a gestao completa de revenue e hosting, escolhe o nivel de apoio e nos executamos na ilha.',
        introEyebrow: 'Pacotes de Servico',
        introTitle: 'Uma estrutura clara que acompanha a forma como o imovel e usado.',
        introBody:
          'Cada pacote foi desenhado para um tipo de operacao diferente: casas vazias, segundas habitacoes, propriedades com mais supervisao, alojamento com revenue e apoio sob pedido.',
        addOnsTitle: addOns.title,
        addOnsSubtitle:
          'Complementos opcionais para elevar a apresentacao, a automacao e a experiencia do hospede.',
        addOnLabel: 'Add-On',
        ctaTitle: 'Sugerimos o pacote que encaixa na operacao real do imovel.',
        ctaBody:
          'Na primeira chamada, percebemos se precisa de cuidado do imovel, suporte a hospedes, revenue e hosting, ou apenas apoio sob pedido.',
        ctaPrimary: 'Marcar Chamada de Diagnostico',
        ctaSecondary: 'Ver Precos',
      }
    : {
        heroEyebrow: 'Service Packages',
        heroTitle: 'Five clear packages for overseas owners.',
        heroSubtitle:
          'From core property care to full revenue and hosting management, choose the level of support you need and we execute on-island.',
        introEyebrow: 'Service Packages',
        introTitle: 'A clear structure that matches how the property is actually used.',
        introBody:
          'Each package is built for a different operating model: vacant homes, second homes, higher-touch oversight, hosted rentals, and flexible on-demand support.',
        addOnsTitle: addOns.title,
        addOnsSubtitle:
          'Optional upgrades to improve presentation, automation, and guest-ready finishing.',
        addOnLabel: 'Add-On',
        ctaTitle: "We'll suggest the package that fits the operation, not the most expensive one.",
        ctaBody:
          "In the first call, we work out whether you need property care, guest support, revenue and hosting management, or just flexible help on the ground.",
        ctaPrimary: 'Book Diagnostic Call',
        ctaSecondary: 'View Pricing',
      };

const pageSchema = [
  breadcrumbJsonLd([
    { name: 'Home', url: routes.home },
    { name: t(lang, 'nav.services'), url: routes.services },
  ]),
  serviceListJsonLd(
    `${t(lang, 'nav.services')} | Madeira Property Concierge`,
    t(lang, 'services.metaDescription'),
    routes.services,
    [...packages.map((item) => item.title), addOns.title],
  ),
];
---

<VisualPageLayout
  lang={lang}
  title={t(lang, 'services.metaTitle')}
  description={t(lang, 'services.metaDescription')}
  heroEyebrow={copy.heroEyebrow}
  heroTitle={copy.heroTitle}
  heroSubtitle={copy.heroSubtitle}
  heroImage={madeiraImages.mercadoMural.src}
  heroAlt={madeiraImages.mercadoMural.alt}
  heroPrimaryCta={{ label: copy.ctaPrimary, href: routes.contact }}
  heroSecondaryCta={{ label: copy.ctaSecondary, href: routes.pricing }}
  jsonLd={pageSchema}
>
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
    <div class="mb-10 grid gap-6 lg:grid-cols-[1fr_auto] lg:items-end">
      <div class="max-w-3xl">
        <p class="eyebrow">{copy.introEyebrow}</p>
        <h2 class="mt-3 text-4xl leading-[1.05] text-charcoal sm:text-5xl">{copy.introTitle}</h2>
        <p class="mt-4 max-w-2xl text-sm leading-relaxed text-charcoal/72 sm:text-base">{copy.introBody}</p>
      </div>
    </div>

    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {packages.map((item, index) => (
        <article class:list={['service-tile reveal aspect-[16/10]', index > 0 ? 'reveal-delay-1' : '']}>
          <img src={tileImages[item.key]} alt={item.title} class="h-full w-full object-cover" loading="lazy" />
          <div class="service-overlay">
            {item.price && (
              <div class="space-y-1">
                <SharedPackageText
                  packageKey={item.key}
                  field="priceHeadline"
                  value={item.price.headline}
                  kind="inline"
                  as="p"
                  class="eyebrow w-fit !border-white/30 !bg-white/10 !text-white/84"
                />
                {item.price.detail && (
                  <SharedPackageText
                    packageKey={item.key}
                    field="priceDetail"
                    value={item.price.detail}
                    kind="block"
                    as="p"
                    class="max-w-md text-sm text-white/76"
                  />
                )}
              </div>
            )}
            <SharedPackageText
              packageKey={item.key}
              field="title"
              value={item.title}
              kind="inline"
              as="h3"
              class="text-3xl text-white"
            />
            <SharedPackageText
              packageKey={item.key}
              field="audience"
              value={item.audience}
              kind="block"
              as="p"
              class="text-sm text-white/82"
            />
            <ul class="space-y-1 text-sm text-white/84">
              {item.servicesBullets.map((bullet, bulletIndex) => (
                <li class="flex items-start gap-2">
                  <span class="mt-1 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-golden-sand"></span>
                  <SharedPackageText
                    packageKey={item.key}
                    field="servicesBullet"
                    index={bulletIndex}
                    value={bullet}
                    kind="block"
                    as="span"
                  />
                </li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8 lg:pb-24">
    <div class="premium-panel p-6 sm:p-8 lg:p-10">
      <div class="mb-6">
        <SharedPackageText
          packageKey={addOns.key}
          field="title"
          value={copy.addOnsTitle}
          kind="inline"
          as="p"
          class="eyebrow"
        />
        <p class="mt-3 max-w-2xl text-sm leading-relaxed text-charcoal/72 sm:text-base">{copy.addOnsSubtitle}</p>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {addOns.features.map((item, featureIndex) => (
          <div class="step-card">
            <p class="text-xs uppercase tracking-[0.12em] text-charcoal/55">{copy.addOnLabel}</p>
            <SharedPackageText
              packageKey={addOns.key}
              field="feature"
              index={featureIndex}
              value={item}
              kind="block"
              as="h3"
              class="mt-2 text-xl text-charcoal"
            />
            <EditableText
              id={addOnQuoteLabel.id}
              selector={addOnQuoteLabel.selector}
              kind={addOnQuoteLabel.kind}
              value={addOnQuoteLabel.value}
              as="p"
              class="js-services-add-on-quote-label mt-2 text-sm font-semibold text-ocean-blue"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="relative isolate overflow-hidden px-4 pb-20 sm:px-6 lg:px-8 lg:pb-24">
    <img
      src={madeiraImages.cliffsPeninsula.src}
      alt={madeiraImages.cliffsPeninsula.alt}
      class="absolute inset-0 -z-20 h-full w-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 -z-10 bg-[linear-gradient(100deg,rgba(11,24,30,0.87)_0%,rgba(11,24,30,0.67)_55%,rgba(11,24,30,0.83)_100%)]"></div>

    <div class="mx-auto max-w-4xl px-4 py-14 text-center text-white sm:px-6 lg:py-20">
      <h2 class="text-balance text-4xl leading-[1.05] text-white sm:text-5xl">{copy.ctaTitle}</h2>
      <p class="mx-auto mt-5 max-w-2xl text-base leading-relaxed text-white/80 sm:text-lg">{copy.ctaBody}</p>

      <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
        <a href={routes.contact} class="inline-flex items-center justify-center rounded-full bg-white px-8 py-3 text-sm font-semibold uppercase tracking-[0.06em] text-charcoal transition-colors hover:bg-golden-sand">{copy.ctaPrimary}</a>
        <a href={routes.pricing} class="inline-flex items-center justify-center rounded-full border border-white/35 bg-white/8 px-8 py-3 text-sm font-semibold uppercase tracking-[0.06em] text-white backdrop-blur transition-colors hover:bg-white/20">{copy.ctaSecondary}</a>
      </div>
    </div>
  </section>
</VisualPageLayout>

<WhatsAppButton lang={lang} />
