---
import EditableLink from '../cms/EditableLink.astro';
import EditableText from '../cms/EditableText.astro';
import VisualPageLayout from './VisualPageLayout.astro';
import WhatsAppButton from '../WhatsAppButton.astro';
import SharedPackageText from '../cms/SharedPackageText.astro';
import { routeMap } from '../../i18n/routes';
import type { Locale } from '../../i18n/utils';
import { breadcrumbJsonLd, serviceListJsonLd } from '../../lib/seo';
import { madeiraImages } from '../../lib/madeiraImages';
import { loadRequiredPageFields } from '../../lib/pageContent/cmsPageText';
import { getSiteChromeContent } from '../../lib/pageContent/siteChrome';
import {
  loadCoreServicePackages,
  loadServicePackages,
  type ServicePackageKey,
} from '../../lib/pageContent/packages';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const routes = routeMap[lang];
const pageId = 'services';
const [packages, allPackages, pageFields, siteChrome] = await Promise.all([
  loadCoreServicePackages(lang),
  loadServicePackages(lang),
  loadRequiredPageFields(pageId, lang, {
    texts: [
      'text:hero-eyebrow',
      'text:hero-title',
      'text:hero-subtitle',
      'text:intro-eyebrow',
      'text:intro-title',
      'text:intro-body',
      'text:add-ons-subtitle',
      'text:add-on-label',
      'text:add-on-quote-label',
      'text:cta-title',
      'text:cta-body',
    ] as const,
    links: [
      'link:primary-cta',
      'link:secondary-cta',
    ] as const,
  }),
  getSiteChromeContent(lang),
]);
const addOns = allPackages.find((item) => item.key === 'addOns');

if (!addOns) {
  throw new Error('Optional add-ons package is missing.');
}

const tileImages: Record<Exclude<ServicePackageKey, 'addOns'>, string> = {
  essentialCare: '/images/library/img-0919.jpg',
  managedCare: madeiraImages.coastalVillageAerial.src,
  premiumCare: madeiraImages.santanaCottageGarden.src,
  revenueHosting: madeiraImages.mercadoMural.src,
  onDemand: madeiraImages.santanaHouseFacade.src,
};

const pageSchema = [
  breadcrumbJsonLd([
    { name: siteChrome.nav.home, url: routes.home },
    { name: siteChrome.nav.services, url: routes.services },
  ]),
  serviceListJsonLd(
    `${siteChrome.nav.services} | ${siteChrome.brand.fullName}`,
    pageFields.texts['text:hero-subtitle'].value,
    routes.services,
    [...packages.map((item) => item.title), addOns.title],
  ),
];
---

<VisualPageLayout
  lang={lang}
  title=""
  description=""
  heroEyebrow={pageFields.texts['text:hero-eyebrow']}
  heroTitle={pageFields.texts['text:hero-title']}
  heroSubtitle={pageFields.texts['text:hero-subtitle']}
  heroImage={madeiraImages.mercadoMural.src}
  heroAlt={madeiraImages.mercadoMural.alt}
  heroPrimaryCta={pageFields.links['link:primary-cta']}
  heroSecondaryCta={pageFields.links['link:secondary-cta']}
  jsonLd={pageSchema}
>
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
    <div class="mb-10 grid gap-6 lg:grid-cols-[1fr_auto] lg:items-end">
      <div class="max-w-3xl">
        <EditableText {...pageFields.texts['text:intro-eyebrow']} as="p" class="eyebrow" />
        <EditableText
          {...pageFields.texts['text:intro-title']}
          as="h2"
          class="mt-3 text-4xl leading-[1.05] text-charcoal sm:text-5xl"
        />
        <EditableText
          {...pageFields.texts['text:intro-body']}
          as="p"
          class="mt-4 max-w-2xl text-sm leading-relaxed text-charcoal/72 sm:text-base"
        />
      </div>
    </div>

    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {packages.map((item, index) => (
        <article class:list={['service-tile reveal', index > 0 ? 'reveal-delay-1' : '']}>
          <img src={tileImages[item.key]} alt={item.title} class="h-full w-full object-cover" loading="lazy" />
          <div class="service-overlay">
            {item.price && (
              <div class="space-y-1">
                <SharedPackageText
                  packageKey={item.key}
                  field="priceHeadline"
                  value={item.price.headline}
                  kind="inline"
                  as="p"
                  class="eyebrow w-fit !border-white/30 !bg-white/10 !text-white/84"
                />
                {item.price.detail && (
                  <SharedPackageText
                    packageKey={item.key}
                    field="priceDetail"
                    value={item.price.detail}
                    kind="inline"
                    as="p"
                    class="max-w-md text-sm text-white/76"
                  />
                )}
              </div>
            )}
            <SharedPackageText
              packageKey={item.key}
              field="title"
              value={item.title}
              kind="inline"
              as="h3"
              class="text-3xl text-white"
            />
            <SharedPackageText
              packageKey={item.key}
              field="audience"
              value={item.audience}
              kind="inline"
              as="p"
              class="text-sm leading-relaxed text-white/90"
            />
            <ul class="space-y-1.5 text-sm text-white/90">
              {item.servicesBullets.map((bullet, bulletIndex) => (
                <li class="flex items-start gap-2">
                  <span class="mt-1 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-golden-sand"></span>
                  <SharedPackageText
                    packageKey={item.key}
                    field="servicesBullet"
                    index={bulletIndex}
                    value={bullet}
                    kind="inline"
                    as="span"
                  />
                </li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8 lg:pb-24">
    <div class="premium-panel p-6 sm:p-8 lg:p-10">
      <div class="mb-6">
        <SharedPackageText
          packageKey={addOns.key}
          field="title"
          value={addOns.title}
          kind="inline"
          as="p"
          class="eyebrow"
        />
        <EditableText
          {...pageFields.texts['text:add-ons-subtitle']}
          as="p"
          class="mt-3 max-w-2xl text-sm leading-relaxed text-charcoal/72 sm:text-base"
        />
      </div>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {addOns.features.map((item, featureIndex) => (
          <div class="step-card">
            <EditableText
              {...pageFields.texts['text:add-on-label']}
              as="p"
              class="text-xs uppercase tracking-[0.12em] text-charcoal/55"
            />
            <SharedPackageText
              packageKey={addOns.key}
              field="feature"
              index={featureIndex}
              value={item}
              kind="inline"
              as="h3"
              class="mt-2 text-xl text-charcoal"
            />
            <EditableText
              {...pageFields.texts['text:add-on-quote-label']}
              as="p"
              class="js-services-add-on-quote-label mt-2 text-sm font-semibold text-ocean-blue"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="relative isolate overflow-hidden px-4 pb-20 sm:px-6 lg:px-8 lg:pb-24">
    <img
      src={madeiraImages.cliffsPeninsula.src}
      alt={madeiraImages.cliffsPeninsula.alt}
      class="absolute inset-0 -z-20 h-full w-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 -z-10 bg-[linear-gradient(100deg,rgba(11,24,30,0.87)_0%,rgba(11,24,30,0.67)_55%,rgba(11,24,30,0.83)_100%)]"></div>

    <div class="mx-auto max-w-4xl px-4 py-14 text-center text-white sm:px-6 lg:py-20">
      <EditableText
        {...pageFields.texts['text:cta-title']}
        as="h2"
        class="text-balance text-4xl leading-[1.05] text-white sm:text-5xl"
      />
      <EditableText
        {...pageFields.texts['text:cta-body']}
        as="p"
        class="mx-auto mt-5 max-w-2xl text-base leading-relaxed text-white/80 sm:text-lg"
      />

      <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
        <EditableLink
          {...pageFields.links['link:primary-cta']}
          class="inline-flex items-center justify-center rounded-full bg-white px-8 py-3 text-sm font-semibold uppercase tracking-[0.06em] text-charcoal transition-colors hover:bg-golden-sand"
        />
        <EditableLink
          {...pageFields.links['link:secondary-cta']}
          class="inline-flex items-center justify-center rounded-full border border-white/35 bg-white/8 px-8 py-3 text-sm font-semibold uppercase tracking-[0.06em] text-white backdrop-blur transition-colors hover:bg-white/20"
        />
      </div>
    </div>
  </section>
</VisualPageLayout>

<WhatsAppButton lang={lang} />
