---
import EditableImage from '../cms/EditableImage.astro';
import EditableLink from '../cms/EditableLink.astro';
import EditableText from '../cms/EditableText.astro';
import VisualPageLayout from './VisualPageLayout.astro';
import WhatsAppButton from '../WhatsAppButton.astro';
import { routeMap } from '../../i18n/routes';
import type { Locale } from '../../i18n/utils';
import { breadcrumbJsonLd } from '../../lib/seo';
import { madeiraImages } from '../../lib/madeiraImages';
import { loadRequiredPageFields } from '../../lib/pageContent/cmsPageText';
import { getSiteChromeContent } from '../../lib/pageContent/siteChrome';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const routes = routeMap[lang];
const pageId = lang === 'en' ? 'en-about' : 'pt-sobre';

const differentiators = ['bilingual', 'design', 'personal', 'network'] as const;

const iconByKey: Record<(typeof differentiators)[number], string> = {
  bilingual: '*',
  design: '+',
  personal: 'o',
  network: '#',
};

const aboutTextIds = [
  'text:hero-eyebrow',
  'text:hero-title',
  'text:hero-subtitle',
  'text:story-eyebrow',
  'text:story-title',
  'text:story-paragraph-1',
  'text:story-paragraph-2',
  'text:story-paragraph-3',
  'text:story-stat-1-value',
  'text:story-stat-1-label',
  'text:story-stat-2-value',
  'text:story-stat-2-label',
  'text:story-stat-3-value',
  'text:story-stat-3-label',
  'text:why-eyebrow',
  'text:why-title',
  'text:why-bilingual-title',
  'text:why-bilingual-description',
  'text:why-design-title',
  'text:why-design-description',
  'text:why-personal-title',
  'text:why-personal-description',
  'text:why-network-title',
  'text:why-network-description',
  'text:quote-eyebrow',
  'text:promise-text',
  'text:cta-title',
  'text:cta-body',
  'text:person-job-title',
] as const;

const aboutLinkIds = [
  'link:primary-cta',
  'link:secondary-cta',
] as const;

const aboutImageIds = [
  'image:story-photo',
] as const;

const [pageFields, siteChrome] = await Promise.all([
  loadRequiredPageFields(pageId, lang, {
    texts: aboutTextIds,
    links: aboutLinkIds,
    images: aboutImageIds,
  }),
  getSiteChromeContent(lang),
]);

const differentiatorCards = [
  {
    key: 'bilingual',
    title: pageFields.texts['text:why-bilingual-title'],
    description: pageFields.texts['text:why-bilingual-description'],
  },
  {
    key: 'design',
    title: pageFields.texts['text:why-design-title'],
    description: pageFields.texts['text:why-design-description'],
  },
  {
    key: 'personal',
    title: pageFields.texts['text:why-personal-title'],
    description: pageFields.texts['text:why-personal-description'],
  },
  {
    key: 'network',
    title: pageFields.texts['text:why-network-title'],
    description: pageFields.texts['text:why-network-description'],
  },
] as const;

const pageSchema = [
  breadcrumbJsonLd([
    { name: siteChrome.nav.home, url: routes.home },
    { name: siteChrome.nav.about, url: routes.about },
  ]),
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Lisa',
    jobTitle: pageFields.texts['text:person-job-title'].value,
    worksFor: {
      '@type': 'Organization',
      name: siteChrome.brand.fullName,
    },
    description: pageFields.texts['text:hero-subtitle'].value,
  },
];
---

<VisualPageLayout
  lang={lang}
  title=""
  description=""
  heroEyebrow={pageFields.texts['text:hero-eyebrow']}
  heroTitle={pageFields.texts['text:hero-title']}
  heroSubtitle={pageFields.texts['text:hero-subtitle']}
  heroImage={madeiraImages.oceanfrontBench.src}
  heroAlt={madeiraImages.oceanfrontBench.alt}
  heroPrimaryCta={pageFields.links['link:primary-cta']}
  heroSecondaryCta={pageFields.links['link:secondary-cta']}
  jsonLd={pageSchema}
>
  <section class="relative isolate overflow-hidden px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
    <div class="pointer-events-none absolute inset-x-0 top-8 -z-10 h-72 bg-[radial-gradient(circle_at_16%_20%,rgba(42,95,125,0.24),transparent_58%)]"></div>
    <div class="pointer-events-none absolute inset-x-0 bottom-0 -z-10 h-80 bg-[radial-gradient(circle_at_82%_84%,rgba(201,120,88,0.2),transparent_56%)]"></div>

    <div class="mx-auto max-w-7xl">
      <div class="relative overflow-hidden rounded-[2rem] border border-charcoal/10 bg-white/74 p-4 shadow-[0_24px_74px_rgba(10,22,32,0.16)] backdrop-blur sm:p-6 lg:p-8">
        <div class="grid gap-8 lg:grid-cols-[minmax(0,0.92fr)_minmax(0,1.08fr)] lg:items-center">
          <div class="relative reveal min-w-0">
            <article class="overflow-hidden rounded-[1.35rem] border border-white/60 bg-white shadow-[0_24px_56px_rgba(5,13,20,0.24)]">
              <EditableImage
                {...pageFields.images['image:story-photo']}
                class="h-auto w-full object-cover"
                loading="lazy"
              />
            </article>
          </div>

          <div class="reveal reveal-delay-1 min-w-0 lg:pr-3">
            <EditableText {...pageFields.texts['text:story-eyebrow']} as="p" class="eyebrow" />
            <EditableText
              {...pageFields.texts['text:story-title']}
              as="h2"
              class="mt-3 text-4xl leading-[1.04] text-charcoal sm:text-5xl"
            />
            <div class="mt-6 space-y-4 text-sm leading-relaxed text-charcoal/76 sm:text-base">
              <EditableText
                {...pageFields.texts['text:story-paragraph-1']}
                as="p"
                class="text-charcoal/86"
              />
              <EditableText {...pageFields.texts['text:story-paragraph-2']} as="p" />
              <EditableText {...pageFields.texts['text:story-paragraph-3']} as="p" />
            </div>

            <div class="mt-7 grid gap-3 sm:grid-cols-3">
              {[
                {
                  value: pageFields.texts['text:story-stat-1-value'],
                  label: pageFields.texts['text:story-stat-1-label'],
                },
                {
                  value: pageFields.texts['text:story-stat-2-value'],
                  label: pageFields.texts['text:story-stat-2-label'],
                },
                {
                  value: pageFields.texts['text:story-stat-3-value'],
                  label: pageFields.texts['text:story-stat-3-label'],
                },
              ].map((item, index) => (
                <article class:list={['rounded-2xl border border-charcoal/10 bg-cream/72 px-4 py-3', index > 0 ? 'reveal reveal-delay-1' : 'reveal']}>
                  <EditableText
                    {...item.value}
                    as="p"
                    class="text-[0.66rem] font-bold uppercase tracking-[0.14em] text-ocean-blue"
                  />
                  <EditableText
                    {...item.label}
                    as="p"
                    class="mt-1 text-xs leading-relaxed text-charcoal/72"
                  />
                </article>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-20 pt-20 sm:px-6 lg:px-8 lg:pb-24 lg:pt-24">
    <div class="premium-panel p-6 sm:p-8 lg:p-10">
      <EditableText {...pageFields.texts['text:why-eyebrow']} as="p" class="eyebrow" />
      <EditableText
        {...pageFields.texts['text:why-title']}
        as="h2"
        class="mt-3 text-4xl leading-[1.05] text-charcoal sm:text-5xl"
      />

      <div class="mt-8 grid gap-4 sm:grid-cols-2">
        {differentiatorCards.map((item, index) => (
          <article class:list={['step-card reveal', index > 0 ? 'reveal-delay-1' : '']}>
            <p class="text-xl">{iconByKey[item.key]}</p>
            <EditableText
              {...item.title}
              as="h3"
              class="mt-2 text-2xl text-charcoal"
            />
            <EditableText
              {...item.description}
              as="p"
              class="mt-2 text-sm leading-relaxed text-charcoal/72"
            />
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="relative isolate overflow-hidden px-4 sm:px-6 lg:px-8">
    <img
      src={madeiraImages.cliffsPeninsula.src}
      alt={madeiraImages.cliffsPeninsula.alt}
      class="absolute inset-0 -z-20 h-full w-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 -z-10 bg-[linear-gradient(100deg,rgba(11,24,30,0.87)_0%,rgba(11,24,30,0.67)_55%,rgba(11,24,30,0.83)_100%)]"></div>

    <div class="mx-auto max-w-4xl px-4 py-14 text-center text-white sm:px-6 lg:py-20">
      <EditableText
        {...pageFields.texts['text:quote-eyebrow']}
        as="p"
        class="eyebrow !border-white/35 !bg-white/10 !text-white/80"
      />
      <blockquote class="mt-4 text-balance text-2xl leading-relaxed text-white/94 sm:text-3xl">
        <EditableText {...pageFields.texts['text:promise-text']} as="span" />
      </blockquote>

      <EditableText
        {...pageFields.texts['text:cta-title']}
        as="h2"
        class="mt-8 text-balance text-4xl leading-[1.05] text-white sm:text-5xl"
      />
      <EditableText
        {...pageFields.texts['text:cta-body']}
        as="p"
        class="mx-auto mt-4 max-w-2xl text-base leading-relaxed text-white/80 sm:text-lg"
      />
      <EditableLink
        {...pageFields.links['link:primary-cta']}
        class="mt-8 inline-flex items-center justify-center rounded-full bg-white px-8 py-3 text-sm font-semibold uppercase tracking-[0.06em] text-charcoal transition-colors hover:bg-golden-sand"
      />
    </div>
  </section>
</VisualPageLayout>

<WhatsAppButton lang={lang} />
