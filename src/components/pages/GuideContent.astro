---
import EditableLink from '../cms/EditableLink.astro';
import EditableText from '../cms/EditableText.astro';
import VisualPageLayout from './VisualPageLayout.astro';
import WhatsAppButton from '../WhatsAppButton.astro';
import { routeMap } from '../../i18n/routes';
import type { Locale } from '../../i18n/utils';
import { breadcrumbJsonLd } from '../../lib/seo';
import { madeiraImages } from '../../lib/madeiraImages';
import { loadRequiredPageFields } from '../../lib/pageContent/cmsPageText';
import { getSiteChromeContent } from '../../lib/pageContent/siteChrome';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const routes = routeMap[lang];
const pageId = lang === 'en' ? 'en-guide' : 'pt-guia';

const [pageFields, siteChrome] = await Promise.all([
  loadRequiredPageFields(pageId, lang, {
    texts: [
      'text:hero-eyebrow',
      'text:hero-title',
      'text:hero-subtitle',
      'text:section-label-overview',
      'text:section-label-checklist',
      'text:section-label-process',
      'text:section-label-risks',
      'text:overview-title',
      'text:overview-body',
      'text:cost-title',
      'text:cost-item-1-label',
      'text:cost-item-1-value',
      'text:cost-item-2-label',
      'text:cost-item-2-value',
      'text:cost-item-3-label',
      'text:cost-item-3-value',
      'text:media-caption',
      'text:checklist-title',
      'text:checklist-item-1',
      'text:checklist-item-2',
      'text:checklist-item-3',
      'text:checklist-item-4',
      'text:process-title',
      'text:process-step-1',
      'text:process-step-2',
      'text:process-step-3',
      'text:process-step-4',
      'text:pitfalls-title',
      'text:pitfall-1',
      'text:pitfall-2',
      'text:pitfall-3',
      'text:pitfall-4',
      'text:cta-title',
      'text:cta-body',
    ] as const,
    links: [
      'link:primary-cta',
      'link:secondary-cta',
    ] as const,
  }),
  getSiteChromeContent(lang),
]);

const processSteps = [
  pageFields.texts['text:process-step-1'],
  pageFields.texts['text:process-step-2'],
  pageFields.texts['text:process-step-3'],
  pageFields.texts['text:process-step-4'],
];

const pageSchema = [
  breadcrumbJsonLd([
    { name: siteChrome.nav.home, url: routes.home },
    { name: pageFields.texts['text:hero-title'].value, url: routes.guide },
  ]),
  {
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: pageFields.texts['text:hero-title'].value,
    description: pageFields.texts['text:hero-subtitle'].value,
    step: processSteps.map((step, index) => ({
      '@type': 'HowToStep',
      position: index + 1,
      name: step.value,
      text: step.value,
    })),
  },
];
---

<VisualPageLayout
  lang={lang}
  title=""
  description=""
  heroEyebrow={pageFields.texts['text:hero-eyebrow']}
  heroTitle={pageFields.texts['text:hero-title']}
  heroSubtitle={pageFields.texts['text:hero-subtitle']}
  heroImage={madeiraImages.villageRuggedMountains.src}
  heroAlt={madeiraImages.villageRuggedMountains.alt}
  heroPrimaryCta={pageFields.links['link:primary-cta']}
  heroSecondaryCta={pageFields.links['link:secondary-cta']}
  jsonLd={pageSchema}
>
  <section class="mx-auto grid max-w-7xl gap-8 px-4 py-16 sm:px-6 lg:grid-cols-[1.02fr_0.98fr] lg:px-8 lg:py-20">
    <article class="premium-panel p-6 sm:p-8">
      <EditableText {...pageFields.texts['text:section-label-overview']} as="p" class="eyebrow" />
      <EditableText {...pageFields.texts['text:overview-title']} as="h2" class="mt-3 text-3xl text-charcoal sm:text-4xl" />
      <EditableText
        {...pageFields.texts['text:overview-body']}
        as="p"
        class="mt-4 text-sm leading-relaxed text-charcoal/75 sm:text-base"
      />

      <EditableText
        {...pageFields.texts['text:cost-title']}
        as="p"
        class="mt-6 text-xs font-semibold uppercase tracking-[0.12em] text-charcoal/55"
      />
      <div class="mt-6 grid gap-3 sm:grid-cols-2">
        {[
          [pageFields.texts['text:cost-item-1-label'], pageFields.texts['text:cost-item-1-value']],
          [pageFields.texts['text:cost-item-2-label'], pageFields.texts['text:cost-item-2-value']],
          [pageFields.texts['text:cost-item-3-label'], pageFields.texts['text:cost-item-3-value']],
        ].map(([label, value]) => (
          <div class="step-card">
            <EditableText {...label} as="p" class="text-xs uppercase tracking-[0.12em] text-charcoal/55" />
            <EditableText {...value} as="p" class="mt-2 text-xl text-charcoal" />
          </div>
        ))}
      </div>
    </article>

    <article class="media-card reveal min-h-[22rem]">
      <img
        src={madeiraImages.mercadoMural.src}
        alt={madeiraImages.mercadoMural.alt}
        class="h-full w-full object-cover"
        loading="lazy"
      />
      <EditableText {...pageFields.texts['text:media-caption']} as="div" class="media-card-caption" />
    </article>
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8 lg:pb-24">
    <div class="grid gap-6 md:grid-cols-3">
      <article class="step-card">
        <EditableText {...pageFields.texts['text:section-label-checklist']} as="p" class="eyebrow !text-[0.58rem]" />
        <EditableText {...pageFields.texts['text:checklist-title']} as="h3" class="mt-3 text-2xl text-charcoal" />
        <ul class="mt-3 space-y-2 text-sm text-charcoal/72">
          {[
            pageFields.texts['text:checklist-item-1'],
            pageFields.texts['text:checklist-item-2'],
            pageFields.texts['text:checklist-item-3'],
            pageFields.texts['text:checklist-item-4'],
          ].map((item) => (
            <li class="flex items-start gap-2">
              <span class="mt-2 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-ocean-blue"></span>
              <EditableText {...item} as="span" />
            </li>
          ))}
        </ul>
      </article>

      <article class="step-card">
        <EditableText {...pageFields.texts['text:section-label-process']} as="p" class="eyebrow !text-[0.58rem]" />
        <EditableText {...pageFields.texts['text:process-title']} as="h3" class="mt-3 text-2xl text-charcoal" />
        <ol class="mt-3 space-y-2 text-sm text-charcoal/72">
          {processSteps.map((item, index) => (
            <li class="flex items-start gap-2">
              <span class="step-index !px-2 !py-1">{index + 1}</span>
              <EditableText {...item} as="span" />
            </li>
          ))}
        </ol>
      </article>

      <article class="step-card">
        <EditableText {...pageFields.texts['text:section-label-risks']} as="p" class="eyebrow !text-[0.58rem]" />
        <EditableText {...pageFields.texts['text:pitfalls-title']} as="h3" class="mt-3 text-2xl text-charcoal" />
        <ul class="mt-3 space-y-2 text-sm text-charcoal/72">
          {[
            pageFields.texts['text:pitfall-1'],
            pageFields.texts['text:pitfall-2'],
            pageFields.texts['text:pitfall-3'],
            pageFields.texts['text:pitfall-4'],
          ].map((item) => (
            <li class="flex items-start gap-2">
              <span class="mt-2 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-terracotta"></span>
              <EditableText {...item} as="span" />
            </li>
          ))}
        </ul>
      </article>
    </div>
  </section>

  <section class="relative isolate overflow-hidden px-4 pb-20 sm:px-6 lg:px-8 lg:pb-24">
    <img
      src={madeiraImages.saoVicenteCoast.src}
      alt={madeiraImages.saoVicenteCoast.alt}
      class="absolute inset-0 -z-20 h-full w-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 -z-10 bg-[linear-gradient(100deg,rgba(11,24,30,0.87)_0%,rgba(11,24,30,0.67)_55%,rgba(11,24,30,0.83)_100%)]"></div>

    <div class="mx-auto max-w-4xl px-4 py-14 text-center text-white sm:px-6 lg:py-20">
      <EditableText
        {...pageFields.texts['text:cta-title']}
        as="h2"
        class="text-balance text-4xl leading-[1.05] text-white sm:text-5xl"
      />
      <EditableText
        {...pageFields.texts['text:cta-body']}
        as="p"
        class="mx-auto mt-4 max-w-2xl text-base leading-relaxed text-white/80 sm:text-lg"
      />
      <EditableLink
        {...pageFields.links['link:primary-cta']}
        class="mt-8 inline-flex items-center justify-center rounded-full bg-white px-8 py-3 text-sm font-semibold uppercase tracking-[0.06em] text-charcoal transition-colors hover:bg-golden-sand"
      />
    </div>
  </section>
</VisualPageLayout>

<WhatsAppButton lang={lang} />
