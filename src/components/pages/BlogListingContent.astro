---
import EditableText from '../cms/EditableText.astro';
import VisualPageLayout from './VisualPageLayout.astro';
import BlogCard from '../blog/BlogCard.astro';
import WhatsAppButton from '../WhatsAppButton.astro';
import type { Locale } from '../../i18n/utils';
import { routeMap } from '../../i18n/routes';
import { getLocalizedBlogPosts } from '../../lib/blogData';
import { breadcrumbJsonLd, absoluteUrl } from '../../lib/seo';
import { madeiraImages } from '../../lib/madeiraImages';
import { loadRequiredPageFields } from '../../lib/pageContent/cmsPageText';
import { getSiteChromeContent } from '../../lib/pageContent/siteChrome';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const routes = routeMap[lang];
const [posts, pageFields, siteChrome] = await Promise.all([
  getLocalizedBlogPosts(lang),
  loadRequiredPageFields(lang === 'en' ? 'en-blog' : 'pt-blog', lang, {
    texts: [
      'text:hero-eyebrow',
      'text:hero-title',
      'text:hero-subtitle',
      'text:featured-label',
      'text:archive-title',
      'text:archive-subtitle',
      'text:posts-label',
      'text:read-more-label',
    ] as const,
    links: [
      'link:primary-cta',
      'link:secondary-cta',
    ] as const,
  }),
  getSiteChromeContent(lang),
]);
const [featuredPost, ...archivePosts] = posts;

const pageSchema = [
  breadcrumbJsonLd([
    { name: siteChrome.nav.home, url: routes.home },
    { name: pageFields.texts['text:hero-title'].value, url: routes.blog },
  ]),
  {
    '@context': 'https://schema.org',
    '@type': 'Blog',
    name: pageFields.texts['text:hero-title'].value,
    description: pageFields.texts['text:hero-subtitle'].value,
    url: absoluteUrl(routes.blog),
    blogPost: posts.map((post) => ({
      '@type': 'BlogPosting',
      headline: post.title,
      datePublished: post.publishedAt,
      dateModified: post.updatedAt ?? post.publishedAt,
      url: absoluteUrl(`${routes.blog}/${post.slug}`),
    })),
  },
];
---

<VisualPageLayout
  lang={lang}
  title=""
  description=""
  heroEyebrow={pageFields.texts['text:hero-eyebrow']}
  heroTitle={pageFields.texts['text:hero-title']}
  heroSubtitle={pageFields.texts['text:hero-subtitle']}
  heroImage={madeiraImages.mountainRiverValley.src}
  heroAlt={madeiraImages.mountainRiverValley.alt}
  heroPrimaryCta={pageFields.links['link:primary-cta']}
  heroSecondaryCta={pageFields.links['link:secondary-cta']}
  jsonLd={pageSchema}
>
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
    {featuredPost && (
      <article class="reveal">
        <a
          href={`/${lang}/blog/${featuredPost.slug}`}
          class="group grid overflow-hidden rounded-[1.7rem] border border-charcoal/12 bg-white/85 shadow-[0_26px_60px_rgba(16,32,43,0.14)] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_34px_70px_rgba(16,32,43,0.18)] md:h-[28rem] md:grid-cols-[1.25fr_1fr]"
        >
          <div class="relative h-64 overflow-hidden sm:h-72 md:h-full">
            <img
              src={featuredPost.coverImage}
              alt={featuredPost.coverAlt}
              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="eager"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-charcoal/50 via-charcoal/10 to-transparent"></div>
          </div>

          <div class="flex flex-col gap-5 p-5 sm:p-6">
            <div>
              <EditableText
                {...pageFields.texts['text:featured-label']}
                as="p"
                class="inline-flex rounded-full border border-charcoal/16 bg-cream/70 px-3 py-1 text-[0.62rem] font-semibold uppercase tracking-[0.12em] text-charcoal/70"
              />
              <h2 class="mt-4 text-3xl leading-tight text-charcoal transition-colors group-hover:text-ocean-blue sm:text-[2.1rem]">
                {featuredPost.title}
              </h2>
              <p class="mt-4 text-sm leading-relaxed text-charcoal/75 sm:text-base">{featuredPost.excerpt}</p>
            </div>

            <div class="flex flex-wrap items-center gap-3 text-[0.68rem] font-semibold uppercase tracking-[0.11em] text-charcoal/60">
              <span>{new Date(featuredPost.publishedAt).toLocaleDateString(lang === 'pt' ? 'pt-PT' : 'en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
              <span aria-hidden>•</span>
              <span>{featuredPost.readingMinutes} min</span>
              <span class="text-ocean-blue">
                <EditableText {...pageFields.texts['text:read-more-label']} as="span" />
                {' '}
                →
              </span>
            </div>
          </div>
        </a>
      </article>
    )}

    <div class="mt-10 flex flex-col gap-4 border-b border-charcoal/12 pb-5 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <EditableText {...pageFields.texts['text:archive-title']} as="h3" class="text-2xl text-charcoal sm:text-3xl" />
        <EditableText
          {...pageFields.texts['text:archive-subtitle']}
          as="p"
          class="mt-2 text-sm leading-relaxed text-charcoal/70 sm:text-base"
        />
      </div>
      <p class="text-[0.7rem] font-semibold uppercase tracking-[0.14em] text-charcoal/55">
        {posts.length}
        {' '}
        <EditableText {...pageFields.texts['text:posts-label']} as="span" />
      </p>
    </div>

    <div class="mt-7 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {archivePosts.map((post, index) => (
        <div class:list={[index > 1 ? 'reveal-delay-1 reveal' : 'reveal']}>
          <BlogCard
            title={post.title}
            excerpt={post.excerpt}
            slug={post.slug}
            publishedAt={post.publishedAt}
            image={post.coverImage}
            imageAlt={post.coverAlt}
            readingMinutes={post.readingMinutes}
            readMoreLabel={pageFields.texts['text:read-more-label']}
            lang={lang}
          />
        </div>
      ))}
    </div>
  </section>
</VisualPageLayout>

<WhatsAppButton lang={lang} />
