---
import { t } from '../../i18n/utils';
import type { Locale } from '../../i18n/utils';
import { routeMap } from '../../i18n/routes';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const routes = routeMap[lang];
---

<section class="py-16 lg:py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Image -->
      <div class="relative">
        <div class="aspect-[4/5] rounded-2xl bg-cream-dark overflow-hidden">
          <img
            src="/images/lisa/portrait.jpg"
            alt="Lisa - Madeira Property Concierge founder"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
        <!-- Decorative accent -->
        <div class="absolute -bottom-4 -right-4 w-24 h-24 bg-terracotta/10 rounded-2xl -z-10"></div>
      </div>

      <!-- Text -->
      <div>
        <p class="text-terracotta font-semibold text-sm uppercase tracking-wider mb-3">{t(lang, 'aboutTeaser.title')}</p>
        <h2 class="text-charcoal">{t(lang, 'aboutTeaser.subtitle')}</h2>
        <p class="mt-6 text-muted leading-relaxed text-lg">
          {t(lang, 'aboutTeaser.description')}
        </p>
        <a
          href={routes.about}
          class="inline-flex items-center gap-2 mt-8 text-forest-green font-semibold hover:text-forest-green-dark transition-colors"
        >
          {t(lang, 'aboutTeaser.cta')}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>
