---
import type { Locale } from '../../i18n/utils';
import { t } from '../../i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

// Placeholder testimonials — to be replaced with real ones
const testimonials = [
  {
    quote: "Lisa transformed our Funchal apartment from a headache into a thriving rental. Her bilingual skills and attention to detail are unmatched.",
    name: "James & Sarah M.",
    location: "London, UK",
    property: "2-bed apartment, Funchal",
  },
  {
    quote: "As a remote owner, I needed someone I could trust completely. Lisa's monthly reports are so detailed, it's like being there myself.",
    name: "Thomas K.",
    location: "Munich, Germany",
    property: "Villa, Calheta",
  },
  {
    quote: "The AL licensing process seemed impossible until Lisa guided us through every step. She saved us months of frustration.",
    name: "Marie & Pierre D.",
    location: "Paris, France",
    property: "3-bed house, Ponta do Sol",
  },
];
---

<section class="py-16 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-12 lg:mb-16">
      <h2 class="text-charcoal">{t(lang, 'testimonials.title')}</h2>
      <p class="mt-4 text-lg text-muted">{t(lang, 'testimonials.subtitle')}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
      {testimonials.map((item) => (
        <div class="p-6 lg:p-8 rounded-xl bg-white border border-cream-dark">
          <!-- Stars -->
          <div class="flex gap-1 text-golden-sand mb-4">
            {[...Array(5)].map(() => (
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
          </div>
          <blockquote class="text-muted leading-relaxed italic font-serif">
            "{item.quote}"
          </blockquote>
          <div class="mt-6 pt-4 border-t border-cream-dark">
            <p class="font-semibold text-charcoal">{item.name}</p>
            <p class="text-sm text-muted">{item.location}</p>
            <p class="text-sm text-forest-green mt-1">{item.property}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
