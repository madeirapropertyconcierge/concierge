---
import type { Locale } from '../../i18n/utils';
import { t } from '../../i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

const testimonialsByLocale: Record<
  Locale,
  Array<{ quote: string; name: string; location: string; property: string }>
> = {
  en: [
    {
      quote:
        'Communication is clear, fast, and practical. Even from Canada, we always know the exact status of the property.',
      name: 'M. C.',
      location: 'Toronto, Canada',
      property: 'Apartment owner, Funchal',
    },
    {
      quote:
        'As local owners, we wanted a higher operational standard. Everything is organized, documented, and handled before issues escalate.',
      name: 'A. S.',
      location: 'Madeira, Portugal',
      property: 'Home owner, São Vicente',
    },
  ],
  pt: [
    {
      quote:
        'A comunicacao e clara, rapida e pratica. Mesmo a partir do Canada, sabemos sempre o estado exato do imovel.',
      name: 'M. C.',
      location: 'Toronto, Canada',
      property: 'Proprietario de apartamento, Funchal',
    },
    {
      quote:
        'Como proprietarios locais, queriamos um padrao operacional mais elevado. Tudo fica organizado, documentado e resolvido antes de escalar.',
      name: 'A. S.',
      location: 'Madeira, Portugal',
      property: 'Proprietario local, São Vicente',
    },
  ],
};

const testimonials = testimonialsByLocale[lang];
---

<section class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8 lg:pb-24">
  <div class="premium-panel p-6 sm:p-8 lg:p-10">
    <div class="mx-auto max-w-3xl text-center">
      <p class="eyebrow">{lang === 'pt' ? 'Prova Social' : 'Social Proof'}</p>
      <h2 class="mt-3 text-4xl leading-[1.05] text-charcoal sm:text-5xl">{t(lang, 'testimonials.title')}</h2>
      <p class="mt-4 text-base leading-relaxed text-charcoal/72 sm:text-lg">{t(lang, 'testimonials.subtitle')}</p>
    </div>

    <div class="mx-auto mt-8 grid max-w-5xl grid-cols-1 gap-5 md:grid-cols-2">
      {testimonials.map((item, index) => (
        <article class:list={['step-card reveal', index > 0 ? 'reveal-delay-1' : '']}>
          <div class="mb-4 flex gap-1 text-golden-sand" aria-label={lang === 'pt' ? 'Avaliacao de 5 estrelas' : '5-star rating'}>
            {[...Array(5)].map(() => (
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
          </div>

          <blockquote class="font-serif text-lg leading-relaxed text-charcoal/82">
            "{item.quote}"
          </blockquote>

          <div class="mt-5 border-t border-charcoal/10 pt-4">
            <p class="font-semibold text-charcoal">{item.name}</p>
            <p class="text-sm text-charcoal/68">{item.location}</p>
            <p class="mt-1 text-sm text-forest-green">{item.property}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
