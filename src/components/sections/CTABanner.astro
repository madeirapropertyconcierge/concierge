---
import { t } from '../../i18n/utils';
import type { Locale } from '../../i18n/utils';
import { routeMap } from '../../i18n/routes';
import { pexelsMadeiraImages } from '../../lib/pexelsImages';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const routes = routeMap[lang];
---

<section class="relative py-20 lg:py-28">
  <img
    src={pexelsMadeiraImages.machicoFireFestival.src}
    alt={pexelsMadeiraImages.machicoFireFestival.alt}
    class="absolute inset-0 h-full w-full object-cover"
    loading="lazy"
  />
  <div class="absolute inset-0 bg-charcoal/70"></div>

  <div class="relative z-10 max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl sm:text-4xl text-white">{t(lang, 'ctaBanner.title')}</h2>
    <p class="mt-4 text-lg text-white/80">{t(lang, 'ctaBanner.subtitle')}</p>
    <a
      href={routes.contact}
      class="inline-flex items-center justify-center mt-8 px-8 py-4 bg-terracotta text-white font-semibold rounded-lg hover:bg-terracotta-dark transition-colors text-lg"
    >
      {t(lang, 'ctaBanner.cta')}
    </a>
  </div>
</section>
