---
import { t } from '../../i18n/utils';
import type { Locale } from '../../i18n/utils';
import { routeMap } from '../../i18n/routes';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const routes = routeMap[lang];

const tiers = [
  { key: 'essentials', color: 'ocean-blue' },
  { key: 'professional', color: 'forest-green' },
  { key: 'premium', color: 'terracotta' },
  { key: 'project', color: 'golden-sand' },
];
---

<section class="py-16 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-12 lg:mb-16">
      <h2 class="text-charcoal">{t(lang, 'serviceOverview.title')}</h2>
      <p class="mt-4 text-lg text-muted">{t(lang, 'serviceOverview.subtitle')}</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 lg:gap-8">
      {tiers.map((tier) => (
        <div class="group relative p-6 lg:p-8 rounded-xl bg-white border border-cream-dark hover:shadow-lg transition-all">
          <div class={`absolute top-0 left-0 w-full h-1 rounded-t-xl bg-${tier.color}`}></div>
          <h3 class="text-xl text-charcoal mt-2">{t(lang, `serviceOverview.tiers.${tier.key}.title`)}</h3>
          <p class="mt-3 text-muted leading-relaxed">{t(lang, `serviceOverview.tiers.${tier.key}.description`)}</p>
          <p class="mt-4 text-lg font-semibold text-forest-green">{t(lang, `serviceOverview.tiers.${tier.key}.price`)}</p>
        </div>
      ))}
    </div>

    <div class="text-center mt-10">
      <a
        href={routes.services}
        class="inline-flex items-center gap-2 px-8 py-3 bg-forest-green text-white font-semibold rounded-lg hover:bg-forest-green-dark transition-colors"
      >
        {t(lang, 'serviceOverview.cta')}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
      </a>
    </div>
  </div>
</section>
