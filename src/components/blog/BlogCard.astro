---
import { t } from '../../i18n/utils';
import type { Locale } from '../../i18n/utils';

interface Props {
  title: string;
  excerpt: string;
  slug: string;
  publishedAt: string;
  image?: string;
  imageAlt?: string;
  readingMinutes?: number;
  lang: Locale;
}

const { title, excerpt, slug, publishedAt, image, imageAlt, readingMinutes, lang } = Astro.props;

const formattedDate = new Date(publishedAt).toLocaleDateString(lang === 'pt' ? 'pt-PT' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="group h-full overflow-hidden rounded-[1.55rem] border border-charcoal/10 bg-white/82 shadow-[0_16px_35px_rgba(16,32,43,0.1)] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_24px_44px_rgba(16,32,43,0.16)]">
  <a href={`/${lang}/blog/${slug}`} class="flex h-full flex-col">
    <div class="relative aspect-[16/10] overflow-hidden">
      {image ? (
        <img
          src={image}
          alt={imageAlt || title}
          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
          loading="lazy"
        />
      ) : (
        <div class="h-full w-full bg-cream"></div>
      )}
      <div class="absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-charcoal/70 to-transparent"></div>
      <p class="absolute bottom-3 left-3 rounded-full border border-white/25 bg-white/14 px-3 py-1 text-[0.6rem] font-semibold uppercase tracking-[0.11em] text-white backdrop-blur">
        {formattedDate}
      </p>
    </div>

    <div class="flex flex-1 flex-col p-5 sm:p-6">
      <p class="text-[0.62rem] font-semibold uppercase tracking-[0.12em] text-charcoal/55">
        {readingMinutes ? `${readingMinutes} min` : '5 min'}
      </p>
      <h3 class="mt-3 text-[1.6rem] leading-tight text-charcoal transition-colors group-hover:text-ocean-blue">{title}</h3>
      <p class="mt-3 flex-1 text-sm leading-relaxed text-charcoal/70">{excerpt}</p>

      <p class="mt-6 inline-flex items-center gap-1 text-[0.68rem] font-semibold uppercase tracking-[0.11em] text-ocean-blue">
        <span>{t(lang, 'blog.readMore')}</span>
        <span aria-hidden>→</span>
      </p>
    </div>
  </a>
</article>
