---
import { routeMap } from '../../i18n/routes';
import { SITE } from '../../lib/constants';
import type { Locale } from '../../i18n/utils';
import { loadCoreServicePackages } from '../../lib/pageContent/packages';
import { getSiteChromeContent, type SiteChromeContent } from '../../lib/pageContent/siteChrome';

interface Props {
  lang: Locale;
  copy?: SiteChromeContent;
}

const { lang, copy: providedCopy } = Astro.props;
const routes = routeMap[lang];
const serviceLinks = await loadCoreServicePackages(lang);
const copy = providedCopy ?? await getSiteChromeContent(lang);
---

<footer class="relative mt-auto overflow-hidden bg-charcoal text-white">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_10%_15%,rgba(247,180,94,0.22),transparent_38%),radial-gradient(circle_at_86%_20%,rgba(36,86,112,0.25),transparent_36%),linear-gradient(180deg,#0d1a24_0%,#09131b_100%)]"></div>

  <div class="relative mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8 lg:py-16">
    <div class="grid gap-10 lg:grid-cols-12">
      <div class="lg:col-span-5">
        <p class="text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-white/70">{copy.brand.fullName}</p>
        <h3 class="mt-3 max-w-sm text-4xl leading-[1.05] text-white sm:text-5xl">{copy.footer.tagline}</h3>
        <p class="mt-5 max-w-md text-sm leading-relaxed text-white/75">
          {copy.footer.description}
        </p>

        <div class="mt-6 flex flex-wrap items-center gap-3">
          <a href={routes.contact} class="inline-flex items-center justify-center rounded-full bg-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.08em] text-charcoal transition-colors hover:bg-golden-sand">
            {copy.nav.cta}
          </a>
          <a href={routes.services} class="inline-flex items-center justify-center rounded-full border border-white/28 bg-white/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-white/20">
            {copy.footer.ctaSecondary}
          </a>
        </div>

        <div class="mt-7 flex gap-2">
          <a href={SITE.social.instagram} target="_blank" rel="noopener noreferrer" aria-label={copy.footer.instagramLabel} class="social-icon">
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href={SITE.social.facebook} target="_blank" rel="noopener noreferrer" aria-label={copy.footer.facebookLabel} class="social-icon">
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href={SITE.social.linkedin} target="_blank" rel="noopener noreferrer" aria-label={copy.footer.linkedinLabel} class="social-icon">
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </div>
      </div>

      <div class="lg:col-span-2">
        <h4 class="footer-heading">{copy.nav.services}</h4>
        <ul class="footer-links">
          {serviceLinks.map((item) => (
            <li>
              <a
                href={routes.services}
                data-cms-owner="packages"
                data-cms-shared-doc="packages"
                data-cms-shared-key={item.key}
                data-cms-shared-field="title"
                data-cms-kind="inline"
                data-cms-source={item.title}
              >
                {item.title}
              </a>
            </li>
          ))}
          <li><a href={routes.pricing}>{copy.nav.pricing}</a></li>
        </ul>
      </div>

      <div class="lg:col-span-2">
        <h4 class="footer-heading">{copy.footer.companyHeading}</h4>
        <ul class="footer-links">
          <li><a href={routes.about}>{copy.nav.about}</a></li>
          <li><a href={routes.howItWorks}>{copy.nav.howItWorks}</a></li>
          <li><a href={routes.blog}>{copy.nav.blog}</a></li>
          <li><a href={routes.faq}>{copy.nav.faq}</a></li>
          <li><a href={routes.guide}>{copy.nav.guide}</a></li>
        </ul>
      </div>

      <div class="lg:col-span-3">
        <h4 class="footer-heading">{copy.nav.contact}</h4>
        <ul class="footer-links">
          <li>
            <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
          </li>
          <li>
            <a href={`tel:${SITE.phone.replace(/\s/g, '')}`}>{SITE.phone}</a>
          </li>
          <li class="!text-white/60">{SITE.address}</li>
          <li class="!text-white/60">{copy.footer.taxIdLabel}: {SITE.legal.taxId}</li>
          <li class="!text-white/60">{SITE.legal.commercialRegistry}</li>
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-col gap-3 border-t border-white/14 pt-6 text-xs text-white/60 sm:flex-row sm:items-center sm:justify-between">
      <p>{copy.footer.copyright}</p>
      <div class="flex flex-wrap gap-6">
        <a
          href="#"
          class="transition-colors hover:text-white"
          data-cms-open-login
          data-admin-allow
        >
          Admin
        </a>
        <a href={routes.privacy} class="transition-colors hover:text-white">{copy.footer.privacy}</a>
        <a href={routes.terms} class="transition-colors hover:text-white">{copy.footer.terms}</a>
        <a href={SITE.legal.complaintsBookUrl} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-white">
          {copy.footer.complaintsBook}
        </a>
        <a href={SITE.legal.adrInfoUrl} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-white">
          {copy.footer.adrInfo}
        </a>
      </div>
    </div>
  </div>
</footer>
