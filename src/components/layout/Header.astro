---
import { routeMap } from '../../i18n/routes';
import { getAlternateRoute } from '../../i18n/routes';
import type { Locale } from '../../i18n/utils';
import { getSiteChromeContent, type SiteChromeContent } from '../../lib/pageContent/siteChrome';
import MobileNav from './MobileNav.astro';

interface Props {
  lang: Locale;
  copy?: SiteChromeContent;
}

const { lang, copy: providedCopy } = Astro.props;
const routes = routeMap[lang];
const currentPath = Astro.url.pathname;
const alternatePath = getAlternateRoute(currentPath, lang === 'en' ? 'pt' : 'en');
const copy = providedCopy ?? await getSiteChromeContent(lang);

const navItems = [
  { label: copy.nav.services, href: routes.services },
  { label: copy.nav.about, href: routes.about },
  { label: copy.nav.howItWorks, href: routes.howItWorks },
  { label: copy.nav.pricing, href: routes.pricing },
  { label: copy.nav.blog, href: routes.blog },
  { label: copy.nav.contact, href: routes.contact },
];
---

<header class="sticky top-3 z-50 px-4 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="header-shell">
      <a href={routes.home} class="flex flex-col leading-none">
        <span class="text-[0.62rem] font-semibold uppercase tracking-[0.22em] text-ocean-blue">{copy.brand.eyebrow}</span>
        <span class="font-serif text-xl tracking-tight text-charcoal sm:text-2xl">{copy.brand.wordmark}</span>
      </a>

      <nav class="hidden xl:flex items-center gap-1" aria-label={copy.mobileNav.navigationLabel}>
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'nav-pill',
              currentPath === item.href || currentPath.startsWith(`${item.href}/`) ? 'nav-pill-active' : '',
            ]}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <div class="flex items-center gap-2 sm:gap-3">
        <a
          href={alternatePath}
          class="inline-flex h-10 min-w-10 items-center justify-center rounded-full border border-charcoal/15 bg-white/70 px-3 text-xs font-semibold uppercase tracking-[0.08em] text-charcoal transition-colors hover:bg-charcoal hover:text-white"
          aria-label={copy.nav.languageToggleAria}
        >
          {copy.nav.languageToggle}
        </a>

        <a
          href={routes.contact}
          class="hidden md:inline-flex items-center justify-center rounded-full bg-charcoal px-5 py-2.5 text-xs font-semibold uppercase tracking-[0.08em] text-white transition-all duration-300 hover:-translate-y-0.5 hover:bg-ocean-blue"
        >
          {copy.nav.cta}
        </a>

        <MobileNav
          navItems={navItems}
          ctaLabel={copy.nav.cta}
          ctaHref={routes.contact}
          openLabel={copy.mobileNav.openLabel}
          closeLabel={copy.mobileNav.closeLabel}
          panelLabel={copy.mobileNav.panelLabel}
          navigationLabel={copy.mobileNav.navigationLabel}
        />
      </div>
    </div>
  </div>
</header>
