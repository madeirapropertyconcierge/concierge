# Generate with: bun run cms:hash-password "your-password"
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=

# Use a fine-grained PAT scoped to this repository only.
# Required permission: Repository -> Contents (Read and write).
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=main

# Contact form email delivery via Brevo (EU email provider, servers in FR/DE).
# Create a free account, then: Brevo dashboard -> SMTP & API -> API Keys.
BREVO_API_KEY=
# Sender address (must be a verified sender/domain in Brevo). Defaults to SITE.email.
BREVO_SENDER_EMAIL=
# Sender display name. Defaults to "Madeira Property Concierge website".
# Enquiries are delivered to the same address as BREVO_SENDER_EMAIL.
BREVO_SENDER_NAME=

# Vercel API token for CLI/API automation.
VERCEL_TOKEN=
# Team/account scope slug from URL, e.g. "my-team" in vercel.com/my-team/project.
VERCEL_SCOPE=
# Team/account id (required when VERCEL_PROJECT_ID is set), e.g. "team_xxx".
VERCEL_ORG_ID=
# Vercel project id from Project Settings -> General -> Project ID.
VERCEL_PROJECT_ID=
